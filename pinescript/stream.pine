//@version=6
indicator(
    "stream",
    overlay = true,
    max_boxes_count = 500,
    max_bars_back = 2000)

// DATA
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

isNQ = syminfo.root == "NQ"
isES = syminfo.root == "ES"
isBTC = str.contains(syminfo.ticker, "BTC")

// CONSTANTS
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

// momentum
VELOCITY_BARS = isNQ ? 8 : isES ? 10 : isBTC ? 12 : 8
VELOCITY_BASELINE_BARS = isNQ ? 120 : isES ? 140 : isBTC ? 160 : 120
SMOOTH_BARS = isNQ ? 6 : isES ? 8 : isBTC ? 10 : 6

// cascade
CASCADE_STRUCTURE_BARS = isNQ ? 6 : isES ? 6 : isBTC ? 8 : 6
CASCADE_LARGE_BAR_RATIO = isNQ ? 4.0 : isES ? 4.2 : isBTC ? 4.5 : 4.0
CASCADE_SWEEP_RATIO = isNQ ? 0.35 : isES ? 0.33 : isBTC ? 0.45 : 0.35
CASCADE_CONTINUATION_BARS = isNQ ? 15 : isES ? 15 : isBTC ? 20 : 15

// expansion
ACCELERATION_BARS = isNQ ? 5 : isES ? 7 : isBTC ? 8 : 5
EXPANSION_STRUCTURE_LOOKBACK = isNQ ? 18 : isES ? 16 : isBTC ? 22 : 18
ACCELERATION_PERCENT = isNQ ? 18.0 : isES ? 20.0 : isBTC ? 14.0 : 18.0
EXPANSION_LEVEL_PERCENT = isNQ ? 115 : isES ? 108 : isBTC ? 100 : 115

// exhaustion
EXHAUSTION_LEVEL_PERCENT = isNQ ? 48 : isES ? 52 : isBTC ? 55 : 48
TREND_MATURE_BARS = isNQ ? 18 : isES ? 18 : isBTC ? 22 : 18
EXHAUSTION_LOOKBACK = isNQ ? 20 : isES ? 18 : isBTC ? 24 : 20
EXHAUSTION_REVERSAL_BARS = isNQ ? 6 : isES ? 7 : isBTC ? 8 : 6

// range
RANGE_BARS = isNQ ? 60 : isES ? 120 : isBTC ? 90 : 60
RANGE_MAGNITUDE_POINTS = isNQ ? 20 : isES ? 18 : isBTC ? 200 : 80

// acceptance
ACCEPTANCE_BARS = isNQ ? 5 : isES ? 6 : isBTC ? 7 : 5

// slow trend
SLOW_TREND_BARS = isNQ ? 120 : isES ? 120 : isBTC ? 90 : 120
SLOW_TREND_COOLDOWN_BARS = 60
SMA_BARS = isNQ ? 90 : isES ? 90 : isBTC ? 70 : 90
SLOPE_LOOKBACK = isNQ ? 10 : isES ? 20 : isBTC ? 10 : 10
STRUCTURE_BARS = isNQ ? 20 : isES ? 14 : isBTC ? 25 : 20
DISTANCE_THRESHOLD = isNQ ? 0.0015 : isES ? 0.0008 : isBTC ? 0.0025 : 0.0015

// FEATURES
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

IS_PERSISTENT_RANGE = isES or isBTC

// INIT
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

// state
var int expansionStartBar = bar_index
var bool isExpansionActive = false
var bool isExpansionUp = false
var float expansionPeakMomentum = 0.0
var float expansionHigh = high
var float expansionLow = low
var color expansionColor = color.black
var bool expansionDirection = false
var box expansionBox = na
var int cascadeBarIndex = na
var bool hasActiveCascade = false
var float cascadeHigh = na
var float cascadeLow = na
var bool cascadeDirection = false
var bool isRangeActive = false
var int rangeStartBar = bar_index
var float rangeHigh = high
var float rangeLow = low
var int lastExhaustionBar = 0
var int lastRangeEndBar = 0
var int eventBarIndex = na
var float eventReferenceHigh = na
var float eventReferenceLow = na
var float eventReferenceMid = na
var bool eventDirectionUp = false
var bool isEvaluatingEvent = false
var int eventType = 0  // 1 range, 2 cascade
var int lastEventBar = na
var int slowTrendDirection = 0  // 1 up, -1 down, 0 none
var int lastSlowTrendBar = 0

// current bar
currentPriceUp = high
currentPriceDown = low
referencePrice = close[VELOCITY_BARS]

// direction from lookback
isUp = high > close[VELOCITY_BARS]
isDown = close[VELOCITY_BARS] > low

// directional velocity (prevents mixing high/low incorrectly)
velocityUp = (currentPriceUp - referencePrice) / VELOCITY_BARS
velocityDown = (referencePrice - currentPriceDown) / VELOCITY_BARS
velocity = math.max(velocityUp, velocityDown)
velocitySma = nz(ta.sma(velocity, VELOCITY_BASELINE_BARS), 1)
velocitySmaSafe = math.max(velocitySma, 0.000001)

// momentum
rawMomentumPercent = (velocity / velocitySmaSafe - 1.0) * 100.0
momentum = ta.sma(rawMomentumPercent, SMOOTH_BARS)

// CASCADE
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

// range
barRange = high - low
rangeAvg = ta.sma(barRange, 20)
rangeSafe = math.max(rangeAvg, syminfo.mintick)

// accepted local structure (ignore wick noise)
acceptedHigh = ta.highest(math.max(open[1], close[1]), CASCADE_STRUCTURE_BARS)
acceptedLow = ta.lowest(math.min(open[1], close[1]), CASCADE_STRUCTURE_BARS)

// sweep
upSweep = math.max(high - acceptedHigh, 0.0)
downSweep = math.max(acceptedLow - low, 0.0)

isLargeBar = barRange > rangeSafe * CASCADE_LARGE_BAR_RATIO

isUpCascadeCandidate =
     high > acceptedHigh
     and upSweep > rangeSafe * CASCADE_SWEEP_RATIO
     and isLargeBar

isDownCascadeCandidate =
     acceptedLow > low
     and downSweep > rangeSafe * CASCADE_SWEEP_RATIO
     and isLargeBar

isDualCascade =
     isUpCascadeCandidate
     and isDownCascadeCandidate

isStopCascadeUp =
     isUpCascadeCandidate
     and (not isDownCascadeCandidate or upSweep > downSweep)

isStopCascadeDown =
     isDownCascadeCandidate
     and (not isUpCascadeCandidate or downSweep > upSweep)

triggerStopCascade =
     isStopCascadeUp
     or isStopCascadeDown

// CONTINUATION CASCADE
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

currentCascadeDirection =
     isStopCascadeUp ? true : isStopCascadeDown ? false : cascadeDirection

isSameDirectionCascade =
     triggerStopCascade
     and hasActiveCascade
     and ((isStopCascadeUp and cascadeDirection) or (isStopCascadeDown and not cascadeDirection))

isContinuationCascadeUp =
     isStopCascadeUp
     and hasActiveCascade
     and isSameDirectionCascade

isContinuationCascadeDown =
     isStopCascadeDown
     and hasActiveCascade
     and isSameDirectionCascade

triggerContinuationCascade =
     isContinuationCascadeUp
     or isContinuationCascadeDown

if triggerStopCascade
    hasActiveCascade := true
    isExpansionActive := false
    expansionPeakMomentum := 0.0
    isRangeActive := false
    cascadeBarIndex := bar_index
    cascadeHigh := high
    cascadeLow := low
    cascadeDirection := currentCascadeDirection

hasActiveCascade :=
     not na(cascadeBarIndex)
     and bar_index - cascadeBarIndex <= CASCADE_CONTINUATION_BARS

// EXPANSION
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

// acceleration
acceleration = momentum - momentum[ACCELERATION_BARS]
isAccelerating = acceleration > ACCELERATION_PERCENT

// structure
isStructureBreakUp = high > ta.highest(high[1], EXPANSION_STRUCTURE_LOOKBACK)
isStructureBreakDown = ta.lowest(low[1], EXPANSION_STRUCTURE_LOOKBACK) > low

// continuation, expansion in same direction as previous expansion
isContinuationExpansion =
     momentum > EXPANSION_LEVEL_PERCENT
     and isUp == isUp[1]
     and momentum > momentum[1]

isExpansion =
     momentum > EXPANSION_LEVEL_PERCENT
     and (isContinuationExpansion or (isUp ? isStructureBreakUp : isStructureBreakDown))

// new expansion direction
isNewTrend =
     not isExpansionActive
     or isExpansionUp != isUp

var bool triggerExpansion = false

triggerExpansionRaw =
     isExpansion
     and not isExpansionActive
     and not triggerStopCascade
     and isNewTrend
     and not isExpansion[1]
     and isNewTrend[1]
     and EXPANSION_LEVEL_PERCENT > momentum[1]

triggerExpansion :=
     barstate.isnew ? triggerExpansionRaw :
     (triggerExpansion or triggerExpansionRaw)

isContinuationExpansionTrigger =
     triggerExpansion
     and not triggerStopCascade
     and isContinuationExpansion
     and not (isUp ? isStructureBreakUp : isStructureBreakDown)

if triggerExpansion and not triggerExpansion[1]
    isExpansionActive := true
    isExpansionUp := isUp
    expansionPeakMomentum := momentum
    expansionDirection := isUp
    expansionStartBar := bar_index

if isExpansionActive
    expansionPeakMomentum := math.max(expansionPeakMomentum, momentum)

// EXHAUSTION
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

// momentum drop
peakSafe = math.max(expansionPeakMomentum, 0.000001)
momentumDropPercent = (peakSafe - momentum) / peakSafe * 100.0
isMomentumDrop = momentumDropPercent > EXHAUSTION_LEVEL_PERCENT

// count bars of reversing momentum
declineCount = 0
for i = 0 to EXHAUSTION_REVERSAL_BARS
    declineCount += momentum[i + 1] > momentum[i] ? 1 : 0
isMomentumReversing = declineCount > EXHAUSTION_REVERSAL_BARS * 0.7

// expansion has existed for reasonable number of bars
isTrendMature = bar_index - expansionStartBar > TREND_MATURE_BARS

// recent high/low
recentSwingLow = ta.lowest(low[1], 6)
recentSwingHigh = ta.highest(high[1], 6)

isUpExhaustionDamage =
     expansionDirection
     and recentSwingLow > low

isDownExhaustionDamage =
     not expansionDirection
     and high > recentSwingHigh

isExhaustionDamage =
     isUpExhaustionDamage
     or isDownExhaustionDamage

exhaustionBarRange = high - low
exhaustionBarRangeAverage = ta.sma(exhaustionBarRange, EXHAUSTION_LOOKBACK)
exhaustionBarRangeSafe = math.max(exhaustionBarRangeAverage, syminfo.mintick)

isExhaustionDamageLargeEnough =
     exhaustionBarRange > exhaustionBarRangeSafe * 1.2

triggerExhaustion =
     isExpansionActive
     and isTrendMature
     and isMomentumDrop
     and isMomentumReversing
     and isExhaustionDamage
     and expansionPeakMomentum > EXPANSION_LEVEL_PERCENT

if triggerExhaustion
    isExpansionActive := false
    expansionPeakMomentum := 0.0
    lastExhaustionBar := bar_index

// RANGE BREAKOUT
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

// highest and lowest in range lookback
rollingHigh = ta.highest(high, RANGE_BARS)
rollingLow = ta.lowest(low, RANGE_BARS)
rollingRange = rollingHigh - rollingLow

isRange = rollingRange <= RANGE_MAGNITUDE_POINTS

// cooldown since last range
barsSinceLastRangeEnd = bar_index - lastRangeEndBar
isRangeCooledDown = barsSinceLastRangeEnd > RANGE_BARS

triggerRangeStart =
     isRange
     and not isExpansionActive
     and not isRangeActive
     and isRangeCooledDown

if triggerRangeStart
    isRangeActive := true
    rangeStartBar := bar_index - RANGE_BARS
    rangeHigh := rollingHigh
    rangeLow := rollingLow

isRangeBreakoutUp =
     isRangeActive
     and high > rangeHigh

isRangeBreakoutDown =
     isRangeActive
     and rangeLow > low

var bool rangeBreakoutDirectionUp = false
var bool triggerRangeBreakout = false

triggerRangeBreakoutRaw =
     isRangeBreakoutUp
     or isRangeBreakoutDown

triggerRangeBreakout :=
     barstate.isnew ? triggerRangeBreakoutRaw :
     (triggerRangeBreakout or triggerRangeBreakoutRaw)

if triggerRangeBreakout and not triggerRangeBreakout[1]
    rangeBreakoutDirectionUp := isRangeBreakoutUp
    isRangeActive := false
    lastRangeEndBar := bar_index

rangeDuration = bar_index - rangeStartBar

// only non-persistent assets kill range on internal activity (NQ, but not ES or BTC)
if (triggerStopCascade or triggerExpansion) and not IS_PERSISTENT_RANGE
    isRangeActive := false

// ACCEPTANCE / REJECTION
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

// cascade event
if triggerStopCascade
    eventBarIndex := bar_index
    eventReferenceHigh := high
    eventReferenceLow := low
    eventReferenceMid := (high + low) * 0.5
    eventDirectionUp := isStopCascadeUp
    isEvaluatingEvent := true
    eventType := 2

// range breakout event
else if triggerRangeBreakout and not triggerRangeBreakout[1]
    eventBarIndex := bar_index
    eventReferenceHigh := rollingHigh
    eventReferenceLow := rollingLow
    eventReferenceMid := (rollingHigh + rollingLow) * 0.5
    eventDirectionUp := rangeBreakoutDirectionUp
    isEvaluatingEvent := true
    eventType := 1

barsSinceBreakoutOrCascade = bar_index - eventBarIndex

isEvaluationDone =
     isEvaluatingEvent
     and barsSinceBreakoutOrCascade == ACCEPTANCE_BARS

isAcceptanceTriggerUp =
     isEvaluationDone
     and not isExpansionActive
     and ((eventType == 1 and eventDirectionUp and open > eventReferenceHigh) or
          (eventType == 2 and eventDirectionUp and open > eventReferenceMid))

isAcceptanceTriggerDown =
     isEvaluationDone
     and not isExpansionActive
     and ((eventType == 1 and not eventDirectionUp and eventReferenceLow > open) or
          (eventType == 2 and not eventDirectionUp and eventReferenceMid > open))

isRejectionTriggerUp =
     isEvaluationDone
     and not isExpansionActive
     and ((eventType == 1 and eventDirectionUp and eventReferenceHigh > open) or
          (eventType == 2 and eventDirectionUp and eventReferenceMid > open))

isRejectionTriggerDown =
     isEvaluationDone
     and not isExpansionActive
     and ((eventType == 1 and not eventDirectionUp and open > eventReferenceLow) or
          (eventType == 2 and not eventDirectionUp and open > eventReferenceMid))

if isEvaluationDone
    isEvaluatingEvent := false
    eventType := 0

// SLOW TREND
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

// track last major event
if triggerExpansion or triggerExhaustion or triggerStopCascade or triggerRangeBreakout
    lastEventBar := bar_index

barsSinceEvent = bar_index - lastEventBar

// significant time has passed since last event
isSlowEnvironment =
     not na(lastEventBar)
     and not isRange
     and barsSinceEvent > SLOW_TREND_BARS

// SMA
sma = ta.sma(ta.sma(close[1], SMA_BARS), 10)
slope = sma - sma[SLOPE_LOOKBACK]
isSlopeUp = slope > 0
isSlopeDown = sma[SLOPE_LOOKBACK] > sma

// distance from SMA
distanceUp = (high - sma) / sma
distanceDown = (sma - low) / sma
isAboveSma = distanceUp > DISTANCE_THRESHOLD
isBelowSma = distanceDown > DISTANCE_THRESHOLD

// structure (entry filter only)
isStructureUp = low > ta.lowest(low[1], STRUCTURE_BARS)
isStructureDown = ta.highest(high[1], STRUCTURE_BARS) > high

// cooldown
barsSinceSlowTrend = bar_index - lastSlowTrendBar

isSlowTrendCooledDown =
     barsSinceSlowTrend > SLOW_TREND_COOLDOWN_BARS

// raw triggers
triggerSlowTrendUpRaw =
     isSlowEnvironment
     and isSlopeUp
     and isAboveSma
     and isStructureUp
     and isSlowTrendCooledDown

triggerSlowTrendDownRaw =
     isSlowEnvironment
     and isSlopeDown
     and isBelowSma
     and isStructureDown
     and isSlowTrendCooledDown

// intrabar stability (no cross-bar persistence)
var bool triggerSlowTrendUp = false
triggerSlowTrendUp :=
     barstate.isnew ? triggerSlowTrendUpRaw :
     (triggerSlowTrendUp or triggerSlowTrendUpRaw)

var bool triggerSlowTrendDown = false
triggerSlowTrendDown :=
     barstate.isnew ? triggerSlowTrendDownRaw :
     (triggerSlowTrendDown or triggerSlowTrendDownRaw)

// update cooldown anchor
if triggerSlowTrendUp or triggerSlowTrendDown
    lastSlowTrendBar := bar_index

// PLOT
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

// expansion
if triggerExpansion
    expansionColor := isUp ? color.new(color.blue, 80) : color.new(color.red, 80)
    expansionBox := box.new(
        left = expansionStartBar,
        right = bar_index,
        top = high,
        bottom = low,
        border_color = expansionColor,
        bgcolor = expansionColor)

if isExpansionActive
    trendLength = bar_index - expansionStartBar + 1
    expansionHigh := ta.highest(high, trendLength)
    expansionLow := ta.lowest(low, trendLength)
    box.set_right(expansionBox, bar_index)
    box.set_top(expansionBox, expansionHigh)
    box.set_bottom(expansionBox, expansionLow)

barcolor(triggerExpansion ? (isUp ? color.blue : color.red) : na)

// cascade
plotshape(
    isStopCascadeUp and not isContinuationCascadeUp,
    title="up cascade",
    location=location.belowbar,
    style=shape.triangleup,
    color=color.blue,
    size=size.small)
plotshape(
    isStopCascadeDown and not isContinuationCascadeDown,
    title="down cascade",
    location=location.abovebar,
    style=shape.triangledown,
    color=color.red,
    size=size.small)

// continuation cascade
plotshape(
    triggerContinuationCascade and isContinuationCascadeUp,
    title="up continuation cascade",
    location=location.belowbar,
    style=shape.diamond,
    color=color.blue, size=size.small)
plotshape(
    triggerContinuationCascade and isContinuationCascadeDown,
    title="down continuation cascade",
    location=location.abovebar,
    style=shape.diamond,
    color=color.red,
    size=size.small)

// range breakout
if triggerRangeBreakout
    line.new(
        x1 = rangeStartBar,
        y1 = (rangeHigh + rangeLow) * 0.5,
        x2 = bar_index,
        y2 = (rangeHigh + rangeLow) * 0.5,
        color = color.new(color.teal, 50),
        style = line.style_dotted,
        width = 2)

    box.new(
        left = rangeStartBar,
        right = bar_index,
        top = rangeHigh,
        bottom = rangeLow,
        border_color = color.new(color.teal, 88),
        bgcolor = color.new(color.teal, 88))

plotshape(
    isRangeBreakoutUp,
    title="range exit up",
    location=location.abovebar,
    style=shape.circle,
    color=color.blue,
    size=size.tiny)
plotshape(
    isRangeBreakoutDown,
    title="range exit down",
    location=location.belowbar,
    style=shape.circle,
    color=color.red,
    size=size.tiny)

// acceptance
plotshape(
    isAcceptanceTriggerUp or isAcceptanceTriggerDown,
    title="acceptance",
    location=location.abovebar,
    style=shape.cross,
    color=color.blue,
    size=size.tiny)

// rejection
plotshape(
    isRejectionTriggerUp or isRejectionTriggerDown,
    title="rejection",
    location=location.belowbar,
    style=shape.xcross,
    color=color.red,
    size=size.tiny)

// slow trend
plotshape(
    triggerSlowTrendUp,
    title = "slow trend up",
    location = location.belowbar,
    style = shape.triangleup,
    color = color.blue,
    size = size.tiny)

plotshape(
    triggerSlowTrendDown,
    title = "slow trend down",
    location = location.abovebar,
    style = shape.triangledown,
    color = color.red,
    size = size.tiny)

plot(sma, title = "sma", color = color.new(color.white, 50), linewidth = 1)

/////////////////////////////////////////////////

// asset name (top right)
assetName =
     isNQ ? "Nasdaq (NQ)" :
     isES ? "S&P 500 (ES)" :
     isBTC ? "Bitcoin (BTC)" :
     "Untagged signal\n" + syminfo.description + " (" + syminfo.ticker + ")"

assetNameColor =
     isNQ ? color.rgb(105, 39, 176) :
     isES ? color.green :
     isBTC ? color.orange :
     color.red

var table assetTable = table.new(position.top_right, 1, 1)

if barstate.islast
    table.cell(assetTable, 0, 0, assetName,
         text_color = assetNameColor,
         text_size = size.normal,
         text_halign = text.align_right,
         bgcolor = na)

// ALERT
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

// Event • Direction + Context • Value

var string alertMessage = na
alertMessage := na

// price
formattedPrice = str.tostring(close, format.mintick)

// percent vs previous close (match tradingview watchlist)
prevClose = request.security(syminfo.tickerid, "D", close[1])
percentChange = (close - prevClose) / prevClose * 100.0
formattedPercent =
     percentChange == 0 ? "0.00%" :
     percentChange > 0 ? "+" + str.tostring(math.abs(percentChange), "0.00") + "%" :
     "-" + str.tostring(math.abs(percentChange), "0.00") + "%"

// cascade move (points)
cascadeMove = math.round(math.abs(high - low)) // round to nearest point
formattedPoints = str.tostring(cascadeMove) + " points"

// MESSAGE
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

getNQmessage() =>
    string message = na

    if triggerStopCascade and not (isContinuationCascadeUp or isContinuationCascadeDown)
        message :=
             "Cascade • " +
             (isStopCascadeUp ? "Bullish short liquidation • " : "Bearish long liquidation • ") +
             formattedPoints

    if triggerContinuationCascade
        message :=
             "Cascade • " +
             (isContinuationCascadeUp ? "Bullish continuation • " : "Bearish continuation • ") +
             formattedPoints

    if triggerExpansion
        message :=
             "Expansion • " +
             (isUp ? "Bullish " : "Bearish ") +
             (isContinuationExpansionTrigger ? "continuation • " : "initiative • ") +
             formattedPercent

    if triggerExhaustion
        message :=
             "Exhaustion • " +
             (expansionDirection ? "Bullish expansion weakening" : "Bearish expansion weakening")

    if triggerRangeBreakout
        message :=
             "Range • " +
             str.tostring(rangeDuration) + " minutes • " +
             (eventDirectionUp ? "Bullish breakout" : "Bearish breakout")

    if isAcceptanceTriggerUp
        message := "Acceptance • Bullish breakout holding • " + formattedPrice

    if isAcceptanceTriggerDown
        message := "Acceptance • Bearish breakout holding • " + formattedPrice

    if isRejectionTriggerUp
        message := "Rejection • Bullish breakout failed"

    if isRejectionTriggerDown
        message := "Rejection • Bearish breakout failed"

    if triggerSlowTrendUp
        message := "Trend • Bullish drift"

    if triggerSlowTrendDown
        message := "Trend • Bearish drift"

    message

getESmessage() =>
    string message = na

    if triggerStopCascade
        message :=
             "Sweep • " +
             (isStopCascadeUp ? "Upside • " : "Downside • ") +
             formattedPoints

    if triggerExpansion
        message :=
             "Drive • " +
             (isUp ? "Upside momentum • " : "Downside momentum • ") +
             formattedPercent

    if triggerExhaustion
        message :=
             "Fade • " +
             (expansionDirection ? "Upside weakening" : "Downside weakening")

    if triggerRangeBreakout
        message :=
             "Structure • " +
             str.tostring(rangeDuration) + " minutes • " +
             (eventDirectionUp ? "Upside push" : "Downside push")


    if isAcceptanceTriggerUp
        message := "Stable • Bullish acceptance • " + formattedPrice

    if isAcceptanceTriggerDown
        message := "Stable • Bearish acceptance • " + formattedPrice

    if isRejectionTriggerUp or isRejectionTriggerDown
        message := "Failure • Revert to range"

    if triggerSlowTrendUp
        message := "Bias • Upside"

    if triggerSlowTrendDown
        message := "Bias • Downside"

    message

getBTCmessage() =>
    string message = na

    if triggerStopCascade
        message :=
             "Liquidation • " +
             (isStopCascadeUp ? "Short squeeze • " : "Long flush • ") +
             formattedPoints

    if triggerExpansion
        message :=
             "Impulse • " +
             (isUp ? "Upside momentum increasing • " : "Downside momentum increasing • ") +
             formattedPercent

    if triggerExhaustion
        message :=
             "Cooldown • " +
             (expansionDirection ? "Upside momentum fading" : "Downside momentum fading")

    if triggerRangeBreakout
        message :=
             "Compression • " +
             str.tostring(rangeDuration) + " minutes • " +
             (eventDirectionUp ? "Break higher" : "Break lower")

    if isAcceptanceTriggerUp
        message := "Holding • Above • " + formattedPrice

    if isAcceptanceTriggerDown
        message := "Holding • Below • " + formattedPrice

    if isRejectionTriggerUp
        message := "Failure • Bearish reversal"

    if isRejectionTriggerDown
        message := "Failure • Bullish reversal"

    if triggerSlowTrendUp
        message := "Drift • Price climbing • " + formattedPrice

    if triggerSlowTrendDown
        message := "Drift • Price falling • " + formattedPrice

    message

// alert message
alertMessage :=
     isNQ ? getNQmessage() :
     isES ? getESmessage() :
     isBTC ? getBTCmessage() : na

// cascades fire on bar close, special case
isCascadeAlert = triggerStopCascade or triggerContinuationCascade

// send alert to webhook
if not na(alertMessage) and (barstate.isconfirmed or not isCascadeAlert)
    alert(alertMessage, alert.freq_once_per_bar)