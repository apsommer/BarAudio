//@version=6
indicator(
    "signal engine",
    overlay = true)

// INPUT
////////////////////////////////////////////////////////////////////////////////////////////////////

// expansion/exhaustion
VELOCITY_BARS = 14
VELOCITY_BASELINE_BARS = 80
SMOOTH_BARS = 4
ACCELERATION_BARS = 3
ACCELERATION_PERCENT = 5.0
EXPANSION_LEVEL_PERCENT = 48
EXHAUSTION_LEVEL_PERCENT = 32
TREND_MATURE_BARS = 10
EXHAUSTION_REVERSAL_BARS = 4

// stop cascade
VELOCITY_SPIKE_RATIO = 2.8
RANGE_EXPANSION_RATIO = 2.4
BAR_STRENGTH_RATIO = 0.78
COMPRESSION_STD_DEV_PERCENT = 0.15
STOP_CASCADE_LOOKBACK = 12

// range breakout
RANGE_PERCENT = 0.18
RANGE_BARS = 120

// INIT
////////////////////////////////////////////////////////////////////////////////////////////////////

// momentum
velocity = math.abs(close - close[VELOCITY_BARS]) / VELOCITY_BARS // Δ price / time
velocitySma = nz(ta.sma(velocity, VELOCITY_BASELINE_BARS), 1) // simple moving average
rawMomentumPercent = (velocity / velocitySma - 1.0) * 100.0 // momentum = velocity / moving average
momentum = ta.sma(rawMomentumPercent, SMOOTH_BARS) // smooth

// direction
isUp = close > close[VELOCITY_BARS]
isDown = close[VELOCITY_BARS] > close

// lifecycle state
var int expansionStartBar = na
var float expansionStartPrice = na
var bool isTrendActive = false
var bool isTrendUp = false
var float trendPeakMomentum = na
var float trendHigh = na
var float trendLow = na
var color trendColor = na
var box trendBox = na

// EXPANSION (momentum increase past threshold)
////////////////////////////////////////////////////////////////////////////////////////////////////

// acceleration = Δ momentum
acceleration = momentum - momentum[ACCELERATION_BARS]
isAccelerating = acceleration > ACCELERATION_PERCENT

// expansion condition
isExpansion =
     momentum > EXPANSION_LEVEL_PERCENT
     and isAccelerating
isNewTrend =
     not isTrendActive
     or isTrendUp != isUp
triggerExpansion =
     isExpansion
     and isNewTrend
     and not (isExpansion and isNewTrend)[1]

if triggerExpansion // else same direction as active trend, do nothing

    isTrendActive := true
    isTrendUp := isUp
    expansionStartBar := bar_index
    expansionStartPrice := close
    trendPeakMomentum := momentum

    // plot /////////////////////////////////////////////////////////
    trendColor := isUp ? color.new(color.blue, 80) : color.new(color.red, 80)
    trendBox := box.new(
        left = expansionStartBar,
        right = bar_index,
        top = close,
        bottom = close,
        border_color = trendColor,
        bgcolor = trendColor)

if isTrendActive

    // track peak momentum
    trendPeakMomentum := math.max(trendPeakMomentum, momentum)

    // plot /////////////////////////////////////////////////////////
    trendLength = bar_index - expansionStartBar + 1
    trendHigh := ta.highest(high, trendLength)
    trendLow  := ta.lowest(low,  trendLength)

    box.set_right(trendBox, bar_index)
    box.set_top(trendBox, trendHigh)
    box.set_bottom(trendBox, trendLow)

barcolor(triggerExpansion ? (isUp ? color.blue : color.red): na)

// alert ////////////////////////////////////////////////////////

// expansion flip (new expansion in opposite direction of active trend)
isOppositeExpansion = triggerExpansion and isTrendActive[1] and isUp != isTrendUp[1]
roundedMomentum = str.tostring(math.round(momentum)) + "%"

flipText =
     (isTrendUp[1] ? "Exhaustion of upward, " : "Exhaustion of downward, ") +
     (isUp ? "expansion of upward " : "expansion of downward ") +
     "with momentum " + roundedMomentum

// new expansion (no active trend)
expansionText =
     (isUp ? "Upside " : "Downside ") +
     ("expansion with momentum " + roundedMomentum)

if triggerExpansion and not barstate.isconfirmed
    alert(isOppositeExpansion ? flipText : expansionText, alert.freq_once_per_bar)

// EXHAUSTION (trend fails to hold momentum after expansion)
////////////////////////////////////////////////////////////////////////////////////////////////////

// drop from peak
momentumDropPercent = (trendPeakMomentum - momentum) / trendPeakMomentum * 100.0
isMomentumDrop = momentumDropPercent > EXHAUSTION_LEVEL_PERCENT

// sustained reversal
isMomentumReversing = true
for i = 0 to EXHAUSTION_REVERSAL_BARS - 2
    isMomentumReversing := isMomentumReversing and momentum[i] > momentum[i + 1]

// ensure trend had time to develop
isTrendMature = bar_index - expansionStartBar > TREND_MATURE_BARS

triggerExhaustion =
     isTrendActive
     and isTrendMature
     and isMomentumDrop
     and isMomentumReversing
     and isNewTrend

if triggerExhaustion
    isTrendActive := false

// alert ////////////////////////////////////////////////////////
trendMovePercent =
     isTrendUp ? (trendHigh - trendLow) / trendLow * 100.0 :
     (trendHigh - trendLow) / trendHigh * 100.0
isTrendProfitable = trendMovePercent > 0

// only append total price move if trend profitable
roundedTrendMove = str.tostring(math.round(math.abs(trendMovePercent), 2)) + "% "
exhaustionText = (isTrendUp ? "Upside " : "Downside ") + "trend exhaustion " +
     (isTrendProfitable ? "after " + roundedTrendMove + "move" : "")
if triggerExhaustion and not barstate.isconfirmed
    alert(exhaustionText, alert.freq_once_per_bar)

// STOP CASCADE
////////////////////////////////////////////////////////////////////////////////////////////////////

// velocity spike
velocityCurrent = math.abs(close - close[1])
velocityAverage = ta.sma(velocityCurrent, 20)
isVelocitySpike = velocityCurrent > velocityAverage * VELOCITY_SPIKE_RATIO

// range expansion
barRange = high - low
rangeAvg = ta.sma(barRange, 20)
isRangeExpansion = barRange > rangeAvg * RANGE_EXPANSION_RATIO

// directional dominance
isStrongUpBar = close > open and (close - open) / barRange > BAR_STRENGTH_RATIO
isStrongDownBar = open > close and (open - close) / barRange > BAR_STRENGTH_RATIO

// compression
isCompressed = COMPRESSION_STD_DEV_PERCENT > ta.stdev(close, 20) / close * 100

// structure break
highestHigh = ta.highest(high[1], STOP_CASCADE_LOOKBACK)
lowestLow = ta.lowest(low[1], STOP_CASCADE_LOOKBACK)
isBreakUp = high > highestHigh
isBreakDown = lowestLow > low

isStopCascadeUp = isVelocitySpike and isRangeExpansion and isStrongUpBar and isCompressed and isBreakUp
isStopCascadeDown = isVelocitySpike and isRangeExpansion and isStrongDownBar and isCompressed and isBreakDown
triggerStopCascade = isStopCascadeUp or isStopCascadeDown

// plot /////////////////////////////////////////////////////////
plotshape(
     isStopCascadeUp,
     title = "up cascade",
     location = location.belowbar,
     style = shape.triangleup,
     color = color.blue,
     size = size.small)
plotshape(
     isStopCascadeDown,
     title = "down cascade",
     location = location.abovebar,
     style = shape.triangledown,
     color = color.red,
     size = size.small)

// alert ////////////////////////////////////////////////////////
cascadeText = (isStrongUpBar ? "Upside " : "Downside ") + "stop cascade "
if triggerStopCascade and not barstate.isconfirmed
    alert(cascadeText, alert.freq_once_per_bar)

// RANGE BREAKOUT
////////////////////////////////////////////////////////////////////////////////////////////////////

// rolling range
rangeHigh = ta.highest(high, RANGE_BARS)
rangeLow = ta.lowest(low, RANGE_BARS)
rangeMid = (rangeHigh + rangeLow) * 0.5
rangeWidthPercent = (rangeHigh - rangeLow) / rangeMid * 100.0
isRange = RANGE_PERCENT > rangeWidthPercent

// breakout
isRangeBreakout = isRange[1] and not isRange
isRangeBreakoutUp = isRangeBreakout and close > rangeHigh[1]
isRangeBreakoutDown = isRangeBreakout and rangeLow[1] > close
triggerRangeExit = isRangeBreakout and (isRangeBreakoutUp or isRangeBreakoutDown)

// plot /////////////////////////////////////////////////////////
plotshape(
     isRangeBreakoutUp,
     title = "range exit up",
     location = location.belowbar,
     style = shape.circle,
     color = color.blue,
     size = size.tiny)
plotshape(
     isRangeBreakoutDown,
     title = "range exit down",
     location = location.abovebar,
     style = shape.circle,
     color = color.blue,
     size = size.tiny)

// alert ////////////////////////////////////////////////////////
rangeText = "Exiting " + str.tostring(RANGE_BARS) + " minute range to " +
     (isRangeBreakoutUp ? "upside" : "downside")

if triggerRangeExit and not barstate.isconfirmed
    alert(rangeText, alert.freq_once_per_bar)