//@version=6
strategy(
    "ZN • 6E • GC",
    overlay = true,
    max_bars_back = 2000,
    pyramiding = 0,
    process_orders_on_close = true,
    calc_on_every_tick = true)

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

// DATA
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

ZN_SYMBOL = "CBOT:ZN1!"
E6_SYMBOL = "CME:6E1!"
GC_SYMBOL = "COMEX_MINI:MGC1!"

isZN = syminfo.root == "ZN"
isE6 = syminfo.root == "6E"
isGC = syminfo.root == "MGC"

znOpen = request.security(ZN_SYMBOL, timeframe.period, open)
e6Open = request.security(E6_SYMBOL, timeframe.period, open)

// SESSION CONTROL
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

// asia: 1810-0200
// london: 0300-1130
// TRANSITION: 0400-0900 end of london, pre-US
// us: 0930-1600

// session windows (entry allowed)
inSessionTimes = "1810-0359,0910-1658"
isInSession = not na(time(timeframe.period, inSessionTimes, "America/New_York"))

// session closing (exit)
marketClosingTime = "1659-1700"
isSessionClosing = not na(time(timeframe.period, marketClosingTime, "America/New_York"))

// ZN
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

ZN_LOOKBACK = 90

znAvg = ta.sma(ta.ema(znOpen, ZN_LOOKBACK), 5)
znSlope = znAvg - znAvg[1]

// trend
isZNsupportive = znOpen > znAvg // and znSlope > 0
isZNhostile = not isZNsupportive // znAvg > znOpen and 0 > znSlope

// 6E
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

E6_LOOKBACK = 75

e6Avg = ta.sma(ta.ema(e6Open, E6_LOOKBACK), 5)
e6Slope = e6Avg - e6Avg[1]

// trend
isE6supportive = e6Open > e6Avg // and e6Slope > 0
isE6hostile = not isE6supportive // e6Avg > e6Open and 0 > e6Slope

// MACRO REGIME
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

MACRO_CHOP_LOOKBACK_LONG = 10
MACRO_CHOP_LOOKBACK_SHORT = 3

// alignment
isMacroSupportive = isZNsupportive and isE6supportive
isMacroHostile = isZNhostile and isE6hostile

znFlip = isZNsupportive != isZNsupportive[1]
e6Flip = isE6supportive != isE6supportive[1]

macroFlip = znFlip or e6Flip
macroFlipCountLong = math.sum(macroFlip ? 1 : 0, MACRO_CHOP_LOOKBACK_LONG)
macroFlipCountShort = math.sum(macroFlip ? 1 : 0, MACRO_CHOP_LOOKBACK_SHORT)

// stability
isMacroCleanLong = macroFlipCountLong <= 1
isMacroCleanShort = macroFlipCountShort <= 1

// GC LOGIC
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

GC_LOOKBACK = 14
GC_EARLY_ALIGNMENT_MIN_BARS  = 2 // wait for stability
GC_EARLY_ALIGNMENT_MAX_BARS = 5 // ensure move is early

var int gcSupportiveBars = 0
var int gcHostileBars = 0

gcAvg = ta.sma(ta.ema(open, GC_LOOKBACK), 5)
gcSlope = gcAvg - gcAvg[1]

// trend
isGCsupportive = open > gcAvg
isGChostile = not isGCsupportive

// count trend bars
gcSupportiveBars := isGCsupportive ? gcSupportiveBars[1] + 1 : 0
gcHostileBars := isGChostile ? gcHostileBars[1] + 1 : 0

// early in new, stable trend
isGCsupportiveEarly =
     isGCsupportive
     and gcSupportiveBars > GC_EARLY_ALIGNMENT_MIN_BARS
     and GC_EARLY_ALIGNMENT_MAX_BARS >= gcSupportiveBars
isGChostileEarly =
     isGChostile
     and gcHostileBars > GC_EARLY_ALIGNMENT_MIN_BARS
     and GC_EARLY_ALIGNMENT_MAX_BARS >= gcHostileBars

// GC TRADE
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

varip bool isBarStable = false
var bool isLongTradeActive = false
var bool isShortTradeActive = false
var float entryPrice = na
var float exitPrice = na
var float profit = na

// calc_on_every_tick has ridiculous problem of pulling previous bar values into this bar just for the very first tick
// creates ghost signals that are not accurate, bar is stable on second tick and later
// additional related problem: first tick arrives at different time when assets pulled from security()
znTime = request.security(ZN_SYMBOL, timeframe.period, time)
e6Time = request.security(E6_SYMBOL, timeframe.period, time)
isBarStable := barstate.isrealtime ? not barstate.isnew and time == znTime and time == e6Time : true

// entry
isLongEntry =
     isBarStable
     and isInSession
     and not isLongTradeActive
     and not isShortTradeActive
     and isMacroSupportive and isMacroSupportive[1]
     and isGCsupportiveEarly
     and isMacroCleanLong

isShortEntry =
     isBarStable
     and isInSession
     and not isLongTradeActive
     and not isShortTradeActive
     and isMacroHostile and isMacroHostile[1]
     and isGChostileEarly
     and isMacroCleanShort

if isLongEntry
    isLongTradeActive := true
    isShortTradeActive := false
    entryPrice := open

if isShortEntry
    isLongTradeActive := false
    isShortTradeActive := true
    entryPrice := open

// exit
isLongExit =
     isBarStable
     and isLongTradeActive
     and (
        (not isMacroSupportive and not isMacroSupportive[1])
        or isSessionClosing
     )

isShortExit =
     isBarStable
     and isShortTradeActive
     and (
        (not isMacroHostile and not isMacroHostile[1])
        or isSessionClosing
     )

if isLongExit
    isLongTradeActive := false
    exitPrice := open
    profit := exitPrice - entryPrice

if isShortExit
    isShortTradeActive := false
    exitPrice := open
    profit := entryPrice - exitPrice

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

// STRATEGY
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

if isGC and isLongEntry
    strategy.entry("long", strategy.long)
if isGC and isShortEntry
    strategy.entry("short", strategy.short)
if isGC and isLongExit
    strategy.close("long")
if isGC and isShortExit
    strategy.close("short")

// PLOT
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

// colors
ZN_color = color.blue
E6_color = color.purple
GC_color = color.yellow
long_color = color.blue
short_color = color.red
win_color = color.green
loss_color = color.red
session_color = color.gray
line_color = color.white

// transparency
bar_transparency = 30
signal_tranparency = 0
line_transparency = 80

// bar color
barColor =
     isZN and isZNsupportive ? color.new(long_color, bar_transparency) :
     isZN and isZNhostile ? color.new(short_color, bar_transparency) :
     isZN ? color.new(ZN_color, bar_transparency) :
     isE6 and isE6supportive ? color.new(long_color, bar_transparency) :
     isE6 and isE6hostile ? color.new(short_color, bar_transparency) :
     isE6 ? color.new(E6_color, bar_transparency) :
     not isInSession ? color.new(session_color, bar_transparency) :
     isGC and isGCsupportive ? color.new(long_color, bar_transparency) :
     isGC and isGChostile ? color.new(short_color, bar_transparency) :
     isGC ? color.new(GC_color, bar_transparency) : na
barcolor(barColor)

// entry
plot(
     isGC and isLongEntry ? open : na,
     style = plot.style_circles,
     color = color.new(long_color, signal_tranparency),
     linewidth = 6)
plot(
     isGC and isShortEntry ? open : na,
     style = plot.style_circles,
     color = color.new(short_color, signal_tranparency),
     linewidth = 6)

// exit
exit_color =
     profit >= 0 ? color.new(win_color, signal_tranparency) :
     color.new(loss_color, signal_tranparency)
plotshape(
     isGC and (isLongExit or isShortExit) ? open : na,
     title = "Long Exit",
     style = shape.xcross,
     location = location.absolute,
     color = exit_color,
     size = size.tiny)

// averages
plot(isZN ? znAvg : na, color = color.new(line_color, line_transparency))
plot(isE6 ? e6Avg : na, color = color.new(line_color, line_transparency))
plot(isGC ? gcAvg : na, color = color.new(line_color, line_transparency))

// ALERT
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

// Event • Direction/State • Context • Value

var string alertMessage = na
alertMessage := na

// macro alert can only fire once every 10 minutes
var int lastMacroAlertTime = 0
var int lastMacroAlertDirection = 0 // -1 hostile, 0 nuetral, 1 supportive
macroCooldownMs = 15 * (60 * 1000)
isMacroCooldownPassed = time - lastMacroAlertTime >= macroCooldownMs

formattedPrice = str.tostring(math.round_to_mintick(open), "#.00")

// calculate p&l in ticks to protect user financial implications spoken aloud
tickSize = syminfo.mintick
longTicks = math.round((open - entryPrice) / tickSize)
shortTicks = math.round((entryPrice - open) / tickSize)

// calculate percent change on ZN to match tradingview watchlist
znPrevClose = request.security(ZN_SYMBOL, "D", close[1])
znSessionPercent = (znOpen - znPrevClose) / znPrevClose * 100.0
formattedZnSessionPercent =
     znSessionPercent == 0 ? "0.00%" :
     znSessionPercent > 0 ? "+" + str.tostring(math.abs(znSessionPercent), "0.00") + "%" :
     "-" + str.tostring(math.abs(znSessionPercent), "0.00") + "%"

// macro supportive
triggerMacroSupportive =
     isGC
     and isMacroSupportive
     and isMacroSupportive[1]
     and isMacroCooldownPassed
     and lastMacroAlertDirection != 1
if triggerMacroSupportive
    if na(alertMessage)
        alertMessage := "Macro • Supportive • Treasuries " + formattedZnSessionPercent + " • Dollar falling"
        lastMacroAlertTime := time
        lastMacroAlertDirection := 1

// macro hostile
triggerMacroHostile =
     isGC
     and isMacroHostile
     and isMacroHostile[1]
     and isMacroCooldownPassed
     and lastMacroAlertDirection != -1
if triggerMacroHostile
    if na(alertMessage)
        alertMessage := "Macro • Hostile • Treasuries " + formattedZnSessionPercent + " • Dollar rising"
        lastMacroAlertTime := time
        lastMacroAlertDirection := -1

// entry
if isGC and isLongEntry
    if na(alertMessage)
        alertMessage := "Entry • Long • " + formattedPrice
if isGC and isShortEntry
    if na(alertMessage)
        alertMessage := "Entry • Short • " + formattedPrice

// exit long
if isGC and isLongExit
    if na(alertMessage)
        isTreasuriesWeaker = not isZNsupportive
        isDollarStronger = not isE6supportive
        exitReason =
             isTreasuriesWeaker and not isDollarStronger ? "Treasuries falling" :
             isDollarStronger and not isTreasuriesWeaker ? "Dollar rising" : "Macro lost"
        exitPnL =
             longTicks >= 0 ? "Plus " + str.tostring(longTicks) + " ticks" :
             "Minus " + str.tostring(math.abs(longTicks)) + " ticks"
        alertMessage := "Exit • Long • " + exitReason + " • " + exitPnL

// exit short
if isGC and isShortExit
    if na(alertMessage)
        isTreasuriesStronger = not isZNhostile
        isDollarWeaker = not isE6hostile
        exitReason =
             isTreasuriesStronger and not isDollarWeaker ? "Treasuries rising" :
             isDollarWeaker and not isTreasuriesStronger ? "Dollar falling" : "Macro lost"
        exitPnL =
             shortTicks >= 0 ? "Plus " + str.tostring(shortTicks) + " ticks" :
             "Minus " + str.tostring(math.abs(shortTicks)) + " ticks"
        alertMessage := "Exit • Short • " + exitReason + " • " + exitPnL

// alert
if not na(alertMessage)
    alert(alertMessage, alert.freq_once_per_bar)