//@version=6
indicator(
    "ZN • 6E • GC",
    overlay = true,
    max_bars_back = 2000)

// INPUT
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

MACRO_VWAP_STD_LOOKBACK = 20

GC_VWAP_STD_LOOKBACK = 20
GC_VWAP_STD_MULTIPLIER = 1.5

// MACRO REGIME
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

// 1 = supportive, 0 = neutral, -1 = hostile

isZNsupportive = request.security(
     "CBOT:ZN1!",
     timeframe.period,
     high - ta.vwap(high) + ta.stdev(high - ta.vwap(high), MACRO_VWAP_STD_LOOKBACK) > 0)

isZNhostile = request.security(
     "CBOT:ZN1!",
     timeframe.period,
     ta.stdev(low - ta.vwap(low), MACRO_VWAP_STD_LOOKBACK) - (low - ta.vwap(low)) > 0)

isE6supportive = request.security(
     "CME:6E1!",
     timeframe.period,
     high - ta.vwap(high) + ta.stdev(high - ta.vwap(high), MACRO_VWAP_STD_LOOKBACK) > 0)

isE6hostile = request.security(
     "CME:6E1!",
     timeframe.period,
     ta.stdev(low - ta.vwap(low), MACRO_VWAP_STD_LOOKBACK) - (low - ta.vwap(low)) > 0)

isMacroSupportive = isZNsupportive and isE6supportive
isMacroHostile = isZNhostile and isE6hostile
isMacroNuetral = not isMacroSupportive and not isMacroHostile

// GC LOGIC
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

GC_vwap_high = ta.vwap(high)
GC_vwap_low = ta.vwap(low)

GC_vwap_distance_high = high - GC_vwap_high
GC_vwap_distance_low = low - GC_vwap_low

GC_vwap_std_high = ta.stdev(GC_vwap_distance_high, GC_VWAP_STD_LOOKBACK)
GC_vwap_std_low = ta.stdev(GC_vwap_distance_low, GC_VWAP_STD_LOOKBACK)

isGcdamagedForLong = GC_vwap_std_low * GC_VWAP_STD_MULTIPLIER + GC_vwap_distance_low < 0
isGcdamagedForShort = GC_vwap_distance_high - GC_vwap_std_high * GC_VWAP_STD_MULTIPLIER > 0

// GC CASCADE
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

GC_CASCADE_TICKS = 100
GC_REPAIR_LOOKBACK = 4

var float GC_downCascadeOriginHigh = na
var float GC_downCascadeLow = na
var float GC_upCascadeOriginLow = na
var float GC_upCascadeHigh = na

GC_range_tick = math.round((high - low) / syminfo.mintick)
GC_isCascade = GC_range_tick > GC_CASCADE_TICKS

GC_isDownCascade = GC_isCascade and low[1] - low > high - high[1]
GC_isUpCascade = GC_isCascade and high - high[1] > low[1] - low

if GC_isDownCascade
    GC_downCascadeOriginHigh := high
    GC_downCascadeLow := low

if GC_isUpCascade
    GC_upCascadeOriginLow := low
    GC_upCascadeHigh := high

GC_hadRecentDownCascade = ta.barssince(GC_isDownCascade) < GC_REPAIR_LOOKBACK
GC_hadRecentUpCascade = ta.barssince(GC_isUpCascade) < GC_REPAIR_LOOKBACK

GC_downCascadeMid = (GC_downCascadeOriginHigh + GC_downCascadeLow) / 2
GC_upCascadeMid = (GC_upCascadeOriginLow + GC_upCascadeHigh) / 2

GC_isRepairingLong = GC_hadRecentDownCascade and low > low[1] and high > high[1]
GC_isRepairingShort = GC_hadRecentUpCascade and high[1] > high and low[1] > low

isLongSignal = isMacroSupportive and isGcdamagedForLong and GC_isRepairingLong and GC_downCascadeMid > low
isShortSignal = isMacroHostile and isGcdamagedForShort and GC_isRepairingShort and high > GC_upCascadeMid

// PLOT
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

ZN_color = color.blue
E6_color = color.purple
GC_color = color.yellow
long_color = color.blue
short_color = color.red

isZN = syminfo.root == "ZN"
isE6 = syminfo.root == "6E"
isGC = syminfo.root == "MGC"

// GC bands
plot(isGC ? GC_vwap_high + GC_vwap_std_high * GC_VWAP_STD_MULTIPLIER : na, color = short_color)
plot(isGC ? GC_vwap_low - GC_vwap_std_low * GC_VWAP_STD_MULTIPLIER : na, color = long_color)

// bar colors (ZN + E6 only)
barColor =
     isZN and isZNsupportive ? long_color :
     isZN and isZNhostile ? short_color :
     isZN ? color.new(ZN_color, 70) :

     isE6 and isE6supportive ? long_color :
     isE6 and isE6hostile ? short_color :
     isE6 ? color.new(E6_color, 70) :

     isGC and isMacroSupportive ? color.new(long_color, 50) :
     isGC and isMacroHostile ? color.new(short_color, 50) :
     isGC ? color.new(GC_color, 70) : na

barcolor(barColor)

// cascade
plotshape(
     isGC and GC_isDownCascade,
     title = "GC Down Cascade",
     style = shape.triangledown,
     location = location.abovebar,
     color = short_color,
     size = size.tiny)

plotshape(
     isGC and GC_isUpCascade,
     title = "GC Up Cascade",
     style = shape.triangleup,
     location = location.belowbar,
     color = long_color,
     size = size.tiny)

// signals
GC_longEntryPlot = GC_downCascadeMid > high ? high : GC_downCascadeMid
GC_shortEntryPlot = low > GC_upCascadeMid ? low : GC_upCascadeMid

plot(
     isGC and isLongSignal ? GC_longEntryPlot : na,
     style = plot.style_circles,
     color = long_color,
     linewidth = 6)

plot(
     isGC and isShortSignal ? GC_shortEntryPlot : na,
     style = plot.style_circles,
     color = short_color,
     linewidth = 6)