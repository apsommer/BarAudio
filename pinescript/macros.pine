//@version=6
indicator(
    "ZN • 6E • GC",
    overlay = true,
    max_bars_back = 2000)

// INPUT
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

ZN_CONFIRM_BARS = 2
E6_CONFIRM_BARS = 2

GC_LOOKBACK = 10
GC_PULLBACK_TICKS = 20

// DATA
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

isZN = syminfo.root == "ZN"
isE6 = syminfo.root == "6E"
isGC = syminfo.root == "MGC"

ZN_open = request.security("CBOT:ZN1!", timeframe.period, open)
ZN_high = request.security("CBOT:ZN1!", timeframe.period, high)
ZN_low = request.security("CBOT:ZN1!", timeframe.period, low)
ZN_close = request.security("CBOT:ZN1!", timeframe.period, close)
ZN_tick_size = request.security("CBOT:ZN1!", timeframe.period, syminfo.mintick)

E6_open = request.security("CME:6E1!", timeframe.period, open)
E6_high = request.security("CME:6E1!", timeframe.period, high)
E6_low = request.security("CME:6E1!", timeframe.period, low)
E6_close = request.security("CME:6E1!", timeframe.period, close)
E6_tick_size = request.security("CME:6E1!", timeframe.period, syminfo.mintick)

GC_open = request.security("COMEX_MINI:MGC1!", timeframe.period, open)
GC_high = request.security("COMEX_MINI:MGC1!", timeframe.period, high)
GC_low = request.security("COMEX_MINI:MGC1!", timeframe.period, low)
GC_close = request.security("COMEX_MINI:MGC1!", timeframe.period, close)
GC_tick_size = request.security("COMEX_MINI:MGC1!", timeframe.period, syminfo.mintick)

// MACRO + GC STATE (range-position model — continuation exhaustion + reversal trigger)
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

// 1 = supportive, 0 = neutral, -1 = hostile

ZN_RANGE_LOOKBACK = 30
ZN_UPPER_BAND = 0.7
ZN_LOWER_BAND = 0.3

E6_RANGE_LOOKBACK = 30
E6_UPPER_BAND = 0.7
E6_LOWER_BAND = 0.3

// ZN
ZN_recent_high = ta.highest(ZN_high[1], ZN_RANGE_LOOKBACK)
ZN_recent_low = ta.lowest(ZN_low[1], ZN_RANGE_LOOKBACK)
ZN_range = ZN_recent_high - ZN_recent_low
ZN_position = ZN_range > 0 ? (ZN_open - ZN_recent_low) / ZN_range : 0.5

ZN_state = ZN_position > ZN_UPPER_BAND ? 1 : ZN_LOWER_BAND > ZN_position ? -1 : 0

// E6
E6_recent_high = ta.highest(E6_high[1], E6_RANGE_LOOKBACK)
E6_recent_low = ta.lowest(E6_low[1], E6_RANGE_LOOKBACK)
E6_range = E6_recent_high - E6_recent_low
E6_position = E6_range > 0 ? (E6_open - E6_recent_low) / E6_range : 0.5

E6_state = E6_position > E6_UPPER_BAND ? 1 : E6_LOWER_BAND > E6_position ? -1 : 0

isMacroSupportive = ZN_state == 1 and E6_state == 1
isMacroHostile = ZN_state == -1 and E6_state == -1
isMacroNuetral = not isMacroSupportive and not isMacroHostile

// GC CASCADE DETECTION
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

// threshold (ticks)
GC_CASCADE_TICKS = 50

// tick movement
GC_body_tick_change = math.round((GC_close - GC_open) / GC_tick_size)
GC_range_tick = math.round((GC_high - GC_low) / GC_tick_size)

// directional bodies
GC_isDownBody = GC_open > GC_close
GC_isUpBody = GC_close > GC_open

// displacement conditions (force, not noise)
GC_hasLargeDownBody = GC_isDownBody and (GC_body_tick_change * -1) > GC_CASCADE_TICKS
GC_hasLargeUpBody = GC_isUpBody and GC_body_tick_change > GC_CASCADE_TICKS

// optional: require expansion (avoid small-range prints)
GC_hasExpansion = GC_range_tick > GC_CASCADE_TICKS

// final cascade signals
GC_isDownCascade = GC_hasLargeDownBody and GC_hasExpansion
GC_isUpCascade = GC_hasLargeUpBody and GC_hasExpansion

// PLOT CASCADES
plotshape(
     isGC and GC_isDownCascade,
     title = "GC Down Cascade",
     style = shape.triangledown,
     location = location.abovebar,
     color = color.red,
     size = size.small)

plotshape(
     isGC and GC_isUpCascade,
     title = "GC Up Cascade",
     style = shape.triangleup,
     location = location.belowbar,
     color = color.blue,
     size = size.small)

isLongSignal = isMacroSupportive
isShortSignal = isMacroHostile

// PLOT
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

ZN_color = color.blue
E6_color = color.purple
GC_color = color.yellow
long_color = color.blue
short_color = color.red

barColor =
     isZN and ZN_state == 1 ? long_color :
     isZN and ZN_state == -1 ? short_color :
     isZN ? color.new(ZN_color, 70) :

     isE6 and E6_state == 1 ? long_color :
     isE6 and E6_state == -1 ? short_color :
     isE6 ? color.new(E6_color, 70) :

     isGC and isLongSignal ? long_color :
     isGC and isShortSignal ? short_color :
     isGC ? GC_color : na

barcolor(barColor)
