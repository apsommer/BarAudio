//@version=6
indicator(
    "ZN • 6E • GC",
    overlay = true,
    max_bars_back = 2000)

// INPUT
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

ZN_CONFIRM_BARS = 2
E6_CONFIRM_BARS = 2

GC_LOOKBACK = 10
GC_PULLBACK_TICKS = 20

// DATA
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

isZN = syminfo.root == "ZN"
isE6 = syminfo.root == "6E"
isGC = syminfo.root == "MGC"

ZN_open = request.security("CBOT:ZN1!", timeframe.period, open)
ZN_high = request.security("CBOT:ZN1!", timeframe.period, high)
ZN_low = request.security("CBOT:ZN1!", timeframe.period, low)
E6_open = request.security("CME:6E1!", timeframe.period, open)
E6_high = request.security("CME:6E1!", timeframe.period, high)
E6_low = request.security("CME:6E1!", timeframe.period, low)
GC_open = request.security("COMEX_MINI:MGC1!", timeframe.period, open)
GC_high = request.security("COMEX_MINI:MGC1!", timeframe.period, high)
GC_low = request.security("COMEX_MINI:MGC1!", timeframe.period, low)

ZN_tick_size = request.security("CBOT:ZN1!", timeframe.period, syminfo.mintick)
E6_tick_size = request.security("CME:6E1!", timeframe.period, syminfo.mintick)
GC_tick_size = request.security("COMEX_MINI:MGC1!", timeframe.period, syminfo.mintick)

// MACRO STATE (range-band classification)
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

// 1 = supportive, 0 = neutral, -1 = hostile

MACRO_RANGE_LOOKBACK = 12
MACRO_UPPER_BAND = 0.65
MACRO_LOWER_BAND = 0.35

ZN_recent_high = ta.highest(ZN_high[1], MACRO_RANGE_LOOKBACK)
ZN_recent_low = ta.lowest(ZN_low[1], MACRO_RANGE_LOOKBACK)
ZN_range = ZN_recent_high - ZN_recent_low
ZN_position = ZN_range > 0 ? (ZN_open - ZN_recent_low) / ZN_range : 0.5

E6_recent_high = ta.highest(E6_high[1], MACRO_RANGE_LOOKBACK)
E6_recent_low = ta.lowest(E6_low[1], MACRO_RANGE_LOOKBACK)
E6_range = E6_recent_high - E6_recent_low
E6_position = E6_range > 0 ? (E6_open - E6_recent_low) / E6_range : 0.5

ZN_state =
     ZN_position > MACRO_UPPER_BAND ? 1 :
     MACRO_LOWER_BAND > ZN_position ? -1 :
     0

E6_state =
     E6_position > MACRO_UPPER_BAND ? 1 :
     MACRO_LOWER_BAND > E6_position ? -1 :
     0

isMacroLong = ZN_state == 1 and E6_state == 1
isMacroShort = ZN_state == -1 and E6_state == -1
isMacroMixed = not isMacroLong and not isMacroShort

// GC LOGIC
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

GC_lastBarPulledBackForLong =
     GC_high[2] > GC_high[1] and
     GC_low[2] > GC_low[1]

GC_lastBarBouncedForShort =
     GC_high[1] > GC_high[2] and
     GC_low[1] > GC_low[2]

GC_isLongSignal =
     isMacroLong and
     GC_lastBarPulledBackForLong

GC_isShortSignal =
     isMacroShort and
     GC_lastBarBouncedForShort

// PLOT
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

ZN_color = color.blue
E6_color = color.purple
GC_color = color.yellow
long_color = color.blue
short_color = color.red

barColor =
     isZN and ZN_state == 1 ? long_color :
     isZN and ZN_state == -1 ? short_color :
     isZN ? color.new(ZN_color, 70) :

     isE6 and E6_state == 1 ? long_color :
     isE6 and E6_state == -1 ? short_color :
     isE6 ? color.new(E6_color, 70) :

     isGC and GC_isLongSignal ? long_color :
     isGC and GC_isShortSignal ? short_color :
     isGC ? GC_color : na

barcolor(barColor)