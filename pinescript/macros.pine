//@version=6
indicator(
    "ZN • 6E • GC",
    overlay = true,
    max_bars_back = 2000)

// DATA
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

isZN = syminfo.root == "ZN"
isE6 = syminfo.root == "6E"
isGC = syminfo.root == "MGC"

ZN_SYMBOL = "CBOT:ZN1!"
E6_SYMBOL = "CME:6E1!"
GC_SYMBOL = "COMEX_MINI:MGC1!"

znOpen = request.security(ZN_SYMBOL, timeframe.period, open)
e6Tick = request.security(E6_SYMBOL, timeframe.period, syminfo.mintick)
e6Open = request.security(E6_SYMBOL, timeframe.period, open)
e6High = request.security(E6_SYMBOL, timeframe.period, high)
e6Low = request.security(E6_SYMBOL, timeframe.period, low)
e6Close = request.security(E6_SYMBOL, timeframe.period, close)

znVwap = request.security(ZN_SYMBOL, timeframe.period, ta.vwap(open))
e6Vwap = request.security(E6_SYMBOL, timeframe.period, ta.vwap(open))
gcVwap = ta.vwap(open)

// SESSION CONTROL
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

// official market open for new futures session
marketOpenTime = "1800-1801"
isNewSession = not na(time(timeframe.period, marketOpenTime, "America/New_York"))

// no trades allowed during 10 min market reopen warmup, close open positions 1 min before market close
inSessionTimes = "1810-1659"
isInSession = not na(time(timeframe.period, inSessionTimes, "America/New_York"))

// BLEND VWAP
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

BLENDED_VWAP_MINUTES = 360

calc_blended_vwap_times(blendedVwapMinutes) =>
    totalMinutes = (18 * 60 + blendedVwapMinutes) % 1440
    endHour = int(math.floor(totalMinutes / 60))
    endMinute = totalMinutes % 60
    "1800-" + str.tostring(endHour, "00") + str.tostring(endMinute, "00")

calc_blended_vwap() =>
    current = ta.vwap(open)
    prev = ta.valuewhen(isNewSession, current[1], 0)
    sessionStartTime = ta.valuewhen(isNewSession, time, 0)
    elapsedMinutes = (time - sessionStartTime) / 60000.0
    c = math.min(1.0, elapsedMinutes / float(BLENDED_VWAP_MINUTES))
    prev + c * (current - prev)

isBlendedVwapTimes = calc_blended_vwap_times(BLENDED_VWAP_MINUTES)
isBlendedVwap = not na(time(timeframe.period, isBlendedVwapTimes, "America/New_York"))

znBlendedVwap = request.security(ZN_SYMBOL, timeframe.period, calc_blended_vwap())
e6BlendedVwap = request.security(E6_SYMBOL, timeframe.period, calc_blended_vwap())
gcBlendedVwap = request.security( GC_SYMBOL, timeframe.period, calc_blended_vwap())

// ZN
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

ZN_LOOKBACK = 30
ZN_POSITION_RATIO = 0.50

// range and position within range
znRecentHigh = request.security(ZN_SYMBOL, timeframe.period, ta.highest(high[1], ZN_LOOKBACK))
znRecentLow = request.security(ZN_SYMBOL, timeframe.period, ta.lowest(low[1], ZN_LOOKBACK))
znRange = znRecentHigh - znRecentLow
znPosition = (znOpen - znRecentLow) / znRange

// trend
isZNsupportive = znPosition >= ZN_POSITION_RATIO
isZNhostile = (1 - ZN_POSITION_RATIO) > znPosition
isZNneutral = not isZNsupportive and not isZNhostile

// 6E
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

E6_LOOKBACK = 24
E6_POSITION_RATIO = 0.50

// range and position within range
e6RecentHigh = request.security(E6_SYMBOL, timeframe.period, ta.highest(high[1], E6_LOOKBACK))
e6RecentLow = request.security(E6_SYMBOL, timeframe.period, ta.lowest(low[1], E6_LOOKBACK))
e6Range = e6RecentHigh - e6RecentLow
e6Position = (e6Open - e6RecentLow) / e6Range

// trend
isE6supportive = e6Position >= E6_POSITION_RATIO
isE6hostile = (1 - E6_POSITION_RATIO) > e6Position
isE6neutral = not isE6supportive and not isE6hostile

// MACRO REGIME
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

isMacroSupportive = isZNsupportive and isE6supportive
isMacroHostile = isZNhostile and isE6hostile
isMacroNuetral = not isMacroSupportive and not isMacroHostile

// GC LOGIC
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

GC_LOOKBACK = 45
GC_POSITION_RATIO = 0.50

// range and position within range
gcRecentHigh = ta.highest(high[1], GC_LOOKBACK)
gcRecentLow = ta.lowest(low[1], GC_LOOKBACK)
gcRange = gcRecentHigh - gcRecentLow
gcPosition = (open - gcRecentLow) / gcRange

// trend
isGCsupportive = gcPosition >= GC_POSITION_RATIO
isGChostile = (1 - GC_POSITION_RATIO) > gcPosition
isGCneutral = not isGCsupportive and not isGChostile

// GC TRADE
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

var bool isLongTradeActive = false
var bool isShortTradeActive = false
var float entryPrice = na
var float exitPrice = na
var float profit = na

// entry
isLongEntry =
     isInSession
     and not isLongTradeActive
     and not isShortTradeActive
     and isMacroSupportive
     and isGCsupportive

isShortEntry =
     isInSession
     and not isLongTradeActive
     and not isShortTradeActive
     and isMacroHostile
     and isGChostile

if isLongEntry
    isLongTradeActive := true
    isShortTradeActive := false
    entryPrice := open

if isShortEntry
    isLongTradeActive := false
    isShortTradeActive := true
    entryPrice := open

// exit = GC loses state
isLongExit =
     isLongTradeActive
     and (not isInSession or not isGCsupportive)

isShortExit =
     isShortTradeActive
     and (not isInSession or not isGChostile)

if isLongExit
    isLongTradeActive := false
    exitPrice := open
    profit := exitPrice - entryPrice

if isShortExit
    isShortTradeActive := false
    exitPrice := open
    profit := entryPrice - exitPrice

// PLOT
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

// colors
ZN_color = color.blue
E6_color = color.purple
GC_color = color.yellow

long_color = color.blue
short_color = color.red
win_color = color.green
loss_color = color.red
session_color = color.yellow

vwap_color = color.white

bar_transparency = 60
signal_tranparency = 0
vwap_transparency = 80

// bar color
barColor =
     isZN and isZNsupportive ? color.new(long_color, bar_transparency) :
     isZN and isZNhostile ? color.new(short_color, bar_transparency) :
     isZN ? color.new(ZN_color, bar_transparency) :
     isE6 and isE6supportive ? color.new(long_color, bar_transparency) :
     isE6 and isE6hostile ? color.new(short_color, bar_transparency) :
     isE6 ? color.new(E6_color, bar_transparency) :
    //  isGC and isMacroSupportive ? color.new(long_color, bar_transparency) :
    //  isGC and isMacroHostile ? color.new(short_color, bar_transparency) :
     isGC and isGCsupportive ? color.new(long_color, bar_transparency) :
     isGC and isGChostile ? color.new(short_color, bar_transparency) :
     isGC ? color.new(GC_color, bar_transparency) : na
barcolor(barColor)

// entry
plot(
     isGC and isLongEntry ? open : na,
     style = plot.style_circles,
     color = color.new(long_color, signal_tranparency),
     linewidth = 6)
plot(
     isGC and isShortEntry ? open : na,
     style = plot.style_circles,
     color = color.new(short_color, signal_tranparency),
     linewidth = 6)

// exit
exit_color =
     not isInSession ? color.new(session_color, signal_tranparency) :
     profit >= 0 ? color.new(win_color, signal_tranparency) :
     color.new(loss_color, signal_tranparency)

plotshape(
     isGC and (isLongExit or isShortExit) ? open : na,
     title = "Long Exit",
     style = shape.xcross,
     location = location.absolute,
     color = exit_color,
     size = size.tiny)

// vwap
plot(isZN and isBlendedVwap ? znVwap : na, color = color.new(vwap_color, vwap_transparency), style = plot.style_linebr)
plot(isE6 and isBlendedVwap ? e6Vwap : na, color = color.new(vwap_color, vwap_transparency), style = plot.style_linebr)
plot(isGC and isBlendedVwap ? gcVwap : na, color = color.new(vwap_color, vwap_transparency), style = plot.style_linebr)
plot(isZN ? znBlendedVwap : na, color = color.new(vwap_color, vwap_transparency))
plot(isE6 ? e6BlendedVwap : na, color = color.new(vwap_color, vwap_transparency))
plot(isGC ? gcBlendedVwap : na, color = color.new(vwap_color, vwap_transparency))

