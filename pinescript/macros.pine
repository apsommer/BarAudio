//@version=6
indicator(
    "ZN • 6E • GC",
    overlay = true,
    max_bars_back = 2000)

// SESSION CONTROL
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

// official market open for new futures session
marketOpenTime = "1800-1801"
marketCloseTime = "1659-1700"
isNewSession = not na(time(timeframe.period, marketOpenTime, "America/New_York"))
isMarketClosing = not na(time(timeframe.period, marketCloseTime, "America/New_York"))

// no trades allowed during 10 min market reopen warmup, close open positions 1 min before market close
inSessionTimes = "1810-1659"
isInSession = not na(time(timeframe.period, inSessionTimes, "America/New_York"))

// DATA
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

isZN = syminfo.root == "ZN"
isE6 = syminfo.root == "6E"
isGC = syminfo.root == "MGC"

ZN_SYMBOL = "CBOT:ZN1!"
E6_SYMBOL = "CME:6E1!"
GC_SYMBOL = "COMEX_MINI:MGC1!"

znOpen = request.security(ZN_SYMBOL, timeframe.period, open)

e6Tick = request.security(E6_SYMBOL, timeframe.period, syminfo.mintick)
e6Open = request.security(E6_SYMBOL, timeframe.period, open)
e6High = request.security(E6_SYMBOL, timeframe.period, high)
e6Low = request.security(E6_SYMBOL, timeframe.period, low)
e6Close = request.security(E6_SYMBOL, timeframe.period, close)

znVwap = request.security(ZN_SYMBOL, timeframe.period, ta.vwap(open))
e6Vwap = request.security(E6_SYMBOL, timeframe.period, ta.vwap(open))
gcVwap = request.security(GC_SYMBOL, timeframe.period, ta.vwap(open))

// blend vwap from previous to new on session start for N minutes, prevents discontinuity at session start
blendedVwapMinutes = 120
isBlendedVwapTimes = "1800-2000"
isBlendedVwap = not na(time(timeframe.period, isBlendedVwapTimes, "America/New_York"))
calc_blended_vwap() =>
    current = ta.vwap(open)
    prev = ta.valuewhen(isMarketClosing, current, 0)
    sessionStartTime = ta.valuewhen(isNewSession, time, 0)
    elapsedMinutes = (time - sessionStartTime) / 60000.0
    c = math.min(1.0, elapsedMinutes / float(blendedVwapMinutes))
    prev + c * (current - prev)

znBlendedVwap = request.security(ZN_SYMBOL, timeframe.period, calc_blended_vwap())
e6BlendedVwap = request.security(E6_SYMBOL, timeframe.period, calc_blended_vwap())
gcBlendedVwap = request.security( GC_SYMBOL, timeframe.period, calc_blended_vwap())

// ZN
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

ZN_LOOKBACK = 24 // lookback for recent range, position consideration
// ZN_POSITION_RATIO = 0.5 // above -> bullish, below -> bearish
ZN_VWAP_DISTANCE_PERCENT = 0.0005

// range and position within range
znRecentHigh = request.security(ZN_SYMBOL, timeframe.period, ta.highest(high[1], ZN_LOOKBACK))
znRecentLow = request.security(ZN_SYMBOL, timeframe.period, ta.lowest(low[1], ZN_LOOKBACK))
znRange = znRecentHigh - znRecentLow
znPosition = (znOpen - znRecentLow) / znRange

// trend
// isZNTrendingUp = znPosition >= ZN_POSITION_RATIO
// isZNTrendingDown = znPosition < (1 - ZN_POSITION_RATIO)

// distance from vwap
znUpperExtension = znBlendedVwap * (1 + ZN_VWAP_DISTANCE_PERCENT)
znLowerExtension = znBlendedVwap * (1 - ZN_VWAP_DISTANCE_PERCENT)

isZNAboveUpperExtension = znOpen > znUpperExtension
isZNBelowLowerExtension = znLowerExtension > znOpen

isZNsupportive = isZNAboveUpperExtension // and isZNTrendingUp
isZNhostile = isZNBelowLowerExtension // and isZNTrendingDown

plot(
     isZN ? znUpperExtension : na,
     color = color.new(color.blue, 60),
     linewidth = 1)

plot(
     isZN ? znLowerExtension : na,
     color = color.new(color.red, 60),
     linewidth = 1)

// 6E
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

E6_LOOKBACK = 18 // lookback for recent range, position consideration
E6_POSITION_RATIO = 0.5 // above -> bullish, below -> bearish

// range and position within range
e6RecentHigh = request.security(E6_SYMBOL, timeframe.period, ta.highest(high[1], E6_LOOKBACK))
e6RecentLow = request.security(E6_SYMBOL, timeframe.period, ta.lowest(low[1], E6_LOOKBACK))
e6Range = e6RecentHigh - e6RecentLow
e6Position = (e6Open - e6RecentLow) / e6Range

// trend
isE6TrendingUp = e6Position > E6_POSITION_RATIO
isE6TrendingDown = e6Position < (1 - E6_POSITION_RATIO)

// vwap
// isE6AboveVwap = e6Open > e6BlendedVwap
// isE6BelowVwap = e6BlendedVwap > e6Open

// trend and vwap
isE6supportive = isE6TrendingUp // and isE6BelowVwap
isE6hostile = isE6TrendingDown // and isE6AboveVwap

// MACRO REGIME
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

isMacroSupportive = isZNsupportive and isE6supportive
isMacroHostile = isZNhostile and isE6hostile
isMacroNuetral = not isMacroSupportive and not isMacroHostile

// GC LOGIC
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

GC_LOOKBACK = 10
GC_POSITION_RATIO = 0.5

gcRecentHigh = ta.highest(high[1], GC_LOOKBACK)
gcRecentLow = ta.lowest(low[1], GC_LOOKBACK)
gcRange = gcRecentHigh - gcRecentLow
gcPosition = (open - gcRecentLow) / gcRange

isGCTrendingUp = gcPosition > GC_POSITION_RATIO
isGCTrendingDown = (1 - GC_POSITION_RATIO) > gcPosition

isGCAboveVwap = open > gcBlendedVwap
isGCBelowVwap = gcBlendedVwap > open

isGCAcceptedBull = isGCTrendingUp and isGCAboveVwap
isGCAcceptedBear = isGCTrendingDown and isGCBelowVwap

isGCDamagedBull = isGCTrendingUp and isGCBelowVwap
isGCDamagedBear = isGCTrendingDown and isGCAboveVwap

// vwap extension

GC_VWAP_PERCENT = 0.028 // 0.02

gcUpperExtension = gcBlendedVwap * (1 + GC_VWAP_PERCENT)
gcLowerExtension = gcBlendedVwap * (1 - GC_VWAP_PERCENT)

isGCOverExtendedUp = open > gcUpperExtension
isGCOverExtendedDown = gcLowerExtension > open

plot(
     isGC ? gcUpperExtension : na,
     color = color.new(color.red, 60),
     linewidth = 1)

plot(
     isGC ? gcLowerExtension : na,
     color = color.new(color.blue, 60),
     linewidth = 1)

// GC TRADE
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

var bool isLongTradeActive = false
var bool isShortTradeActive = false
var float entryPrice = na
var float exitPrice = na
var float profit = na

// temp
tp = 10
sl = 10

// entry
isLongEntry =
     isInSession
     and not isLongTradeActive
     and not isShortTradeActive
     and isMacroSupportive
     and isGCTrendingUp
     and not isGCOverExtendedUp
isShortEntry =
     isInSession
     and not isLongTradeActive
     and not isShortTradeActive
     and isMacroHostile
     and isGCTrendingDown
     and not isGCOverExtendedDown

if isLongEntry
    isLongTradeActive := true
    isShortTradeActive := false
    entryPrice := open
if isShortEntry
    isLongTradeActive := false
    isShortTradeActive := true
    entryPrice := open

// take profit
isLongTakeProfit =
     isLongTradeActive
     and open > entryPrice + tp
isShortTakeProfit =
     isShortTradeActive
     and entryPrice - tp > open

// stop loss
isLongStopLoss =
     isLongTradeActive
     and entryPrice - sl > open
isShortStopLoss =
     isShortTradeActive
     and open > entryPrice + sl

// exit
isLongExit =
     isLongTradeActive
     and (not isInSession or isLongTakeProfit or isLongStopLoss)
isShortExit =
     isShortTradeActive
     and (not isInSession or isShortTakeProfit or isShortStopLoss)

if isLongExit
    isLongTradeActive := false
    exitPrice := open
    profit := exitPrice - entryPrice
if isShortExit
    isShortTradeActive := false
    exitPrice := open
    profit := entryPrice - exitPrice

// PLOT
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

ZN_color = color.blue
E6_color = color.purple
GC_color = color.yellow
long_color = color.blue
short_color = color.red
vwap_color = color.new(color.white, 70)

// bar color
barColor =
     isZN and isZNsupportive ? long_color :
     isZN and isZNhostile ? short_color :
     isZN ? color.new(ZN_color, 70) :
     isE6 and isE6supportive ? long_color :
     isE6 and isE6hostile ? short_color :
     isE6 ? color.new(E6_color, 50) :
     isGC and isMacroSupportive ? color.new(long_color, 70) :
     isGC and isMacroHostile ? color.new(short_color, 70) :
     isGC ? color.new(GC_color, 70) : na
barcolor(barColor)

// entry
plot(
     isGC and isLongEntry ? open : na,
     style = plot.style_circles,
     color = long_color,
     linewidth = 6)
plot(
     isGC and isShortEntry ? open : na,
     style = plot.style_circles,
     color = short_color,
     linewidth = 6)

// exit
exitColor =
     isLongTakeProfit or isShortTakeProfit ? color.green :
     isLongStopLoss or isShortStopLoss ? color.red :
     color.yellow
plotshape(
     isGC and isLongExit ? open : na,
     title = "Long Exit",
     style = shape.xcross,
     location = location.absolute,
     color = exitColor,
     size = size.tiny)
plotshape(
     isGC and isShortExit ? open : na,
     title = "Short Exit",
     style = shape.xcross,
     location = location.absolute,
     color = exitColor,
     size = size.tiny)

// vwap
plot(isZN and isBlendedVwap ? znVwap : na, color = vwap_color, style = plot.style_linebr)
plot(isE6 and isBlendedVwap ? e6Vwap : na, color = vwap_color, style = plot.style_linebr)
plot(isGC and isBlendedVwap ? gcVwap : na, color = vwap_color, style = plot.style_linebr)
plot(isZN ? znBlendedVwap : na, color = vwap_color)
plot(isE6 ? e6BlendedVwap : na, color = vwap_color)
plot(isGC ? gcBlendedVwap : na, color = vwap_color)

