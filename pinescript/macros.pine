//@version=6
indicator(
    "ZN • 6E • GC",
    overlay = true,
    max_bars_back = 2000)

// INPUT
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////


// SESSION CONTROL
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

// official market open for new futures session
marketOpenTime = "1800-1801"
marketCloseTime = "1659-1700"
isNewSession = not na(time(timeframe.period, marketOpenTime, "America/New_York"))
isMarketClosing = not na(time(timeframe.period, marketCloseTime, "America/New_York"))

// no trades allowed during 10 min market reopen warmup, close open positions 1 min before market close
inSessionTimes = "1810-1659"
isInSession = not na(time(timeframe.period, inSessionTimes, "America/New_York"))

// DATA
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

ZN_SYMBOL = "CBOT:ZN1!"
E6_SYMBOL = "CME:6E1!"
GC_SYMBOL = "COMEX_MINI:MGC1!"

znOpen = request.security(ZN_SYMBOL, timeframe.period, open)

e6Tick = request.security(E6_SYMBOL, timeframe.period, syminfo.mintick)
e6Open = request.security(E6_SYMBOL, timeframe.period, open)
e6High = request.security(E6_SYMBOL, timeframe.period, high)
e6Low = request.security(E6_SYMBOL, timeframe.period, low)
e6Close = request.security(E6_SYMBOL, timeframe.period, close)

znVwap = request.security(ZN_SYMBOL, timeframe.period, ta.vwap(open))
e6Vwap = request.security(E6_SYMBOL, timeframe.period, ta.vwap(open))
gcVwap = request.security(GC_SYMBOL, timeframe.period, ta.vwap(open))

// blend vwap from previous to new on session start for N minutes, prevents discontinuity at session start
blendedVwapMinutes = 90
isBlendedVwapTimes = "1800-1930"
isBlendedVwap = not na(time(timeframe.period, isBlendedVwapTimes, "America/New_York"))
calc_blended_vwap() =>
    current = ta.vwap(open)
    prev = ta.valuewhen(isMarketClosing, current, 0)
    sessionStartTime = ta.valuewhen(isNewSession, time, 0)
    elapsedMinutes = (time - sessionStartTime) / 60000.0
    c = math.min(1.0, elapsedMinutes / float(blendedVwapMinutes))
    prev + c * (current - prev)

znBlendedVwap = request.security(ZN_SYMBOL, timeframe.period, calc_blended_vwap())
e6BlendedVwap = request.security(E6_SYMBOL, timeframe.period, calc_blended_vwap())
gcBlendedVwap = request.security( GC_SYMBOL, timeframe.period, calc_blended_vwap())

// ZN
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

// 1 = supportive, 0 = neutral, -1 = hostile

ZN_LOOKBACK = 25 // lookback for recent range, position consideration
ZN_POSITION_RATIO = 0.62 // above -> bullish, below -> bearish

// range and position within range
znRecentHigh = request.security(ZN_SYMBOL, timeframe.period, ta.highest(high[1], ZN_LOOKBACK))
znRecentLow = request.security(ZN_SYMBOL, timeframe.period, ta.lowest(low[1], ZN_LOOKBACK))
znRange = znRecentHigh - znRecentLow
znPosition = (znOpen - znRecentLow) / znRange

// trend
isZNTrendingUp = znPosition > ZN_POSITION_RATIO
isZNTrendingDown = znPosition < (1 - ZN_POSITION_RATIO)

// trend and vwap
isZNsupportive = isZNTrendingUp and znOpen > znBlendedVwap
isZNhostile = isZNTrendingDown and znOpen < znBlendedVwap

// 6E
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

E6_LOOKBACK = 20 // lookback for recent range, position consideration
E6_POSITION_RATIO = 0.65 // above -> bullish, below -> bearish

// range and position within range
e6RecentHigh = request.security(E6_SYMBOL, timeframe.period, ta.highest(high[1], E6_LOOKBACK))
e6RecentLow = request.security(E6_SYMBOL, timeframe.period, ta.lowest(low[1], E6_LOOKBACK))
e6Range = e6RecentHigh - e6RecentLow
e6Position = (e6Open - e6RecentLow) / e6Range

// trend
isE6TrendingUp = e6Position > E6_POSITION_RATIO
isE6TrendingDown = e6Position < (1 - E6_POSITION_RATIO)

// trend and vwap
isE6supportive = isE6TrendingUp and e6Open > e6BlendedVwap
isE6hostile = isE6TrendingDown and e6Open < e6BlendedVwap

// MACRO REGIME
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

// 1 = supportive, 0 = neutral, -1 = hostile
isMacroSupportive = isZNsupportive and isE6supportive
isMacroHostile = isZNhostile and isE6hostile
isMacroNuetral = not isMacroSupportive and not isMacroHostile

// GC LOGIC
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

MACRO_ENTRY_PERSISTENCE_BARS = 2
MACRO_EXIT_PERSISTENCE_BARS = 2

var int macroPersistentState = 0
var int macroSupportiveCount = 0
var int macroHostileCount = 0
var int macroNotSupportiveCount = 0
var int macroNotHostileCount = 0
var bool isLongTradeActive = false
var bool isShortTradeActive = false

// count consecutive regime bars
macroSupportiveCount := isMacroSupportive ? macroSupportiveCount[1] + 1 : 0
macroHostileCount := isMacroHostile ? macroHostileCount[1] + 1 : 0
macroNotSupportiveCount := isMacroNuetral or isMacroHostile ? macroNotSupportiveCount[1] + 1 : 0
macroNotHostileCount := isMacroNuetral or isMacroSupportive ? macroNotHostileCount[1] + 1 : 0

// entry into supportive / hostile
if macroPersistentState == 0 and macroSupportiveCount > MACRO_ENTRY_PERSISTENCE_BARS
    macroPersistentState := 1
if macroPersistentState == 0 and macroHostileCount > MACRO_ENTRY_PERSISTENCE_BARS
    macroPersistentState := -1

// exit back to neutral
if macroPersistentState == 1 and macroNotSupportiveCount > MACRO_EXIT_PERSISTENCE_BARS
    macroPersistentState := 0
if macroPersistentState == -1 and macroNotHostileCount > MACRO_EXIT_PERSISTENCE_BARS
    macroPersistentState := 0

// persistence in regime
isMacroSupportivePersistent = macroPersistentState == 1
isMacroHostilePersistent = macroPersistentState == -1
isMacroNuetralPersistent = macroPersistentState == 0

// GC TRADE
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

var float entryPrice = open
var float exitPrice = open
var float profit = 0.0

isLongSignal =
     not isLongTradeActive
     and not isShortTradeActive
     and isMacroSupportivePersistent
     and isInSession

isShortSignal =
     not isLongTradeActive
     and not isShortTradeActive
     and isMacroHostilePersistent
     and isInSession

isLongExit =
     isLongTradeActive
     and (not isInSession or isMacroNuetralPersistent)

isShortExit =
     isShortTradeActive
     and (not isInSession or isMacroNuetralPersistent)

// update state
if isLongSignal
    isLongTradeActive := true
    isShortTradeActive := false
if isShortSignal
    isLongTradeActive := false
    isShortTradeActive := true
if isLongExit
    isLongTradeActive := false
if isShortExit
    isShortTradeActive := false

// calculate p&l
if isLongSignal or isShortSignal
    entryPrice := open
if isLongExit or isShortExit
    exitPrice := open
    profit := isLongExit ? exitPrice - entryPrice : entryPrice - exitPrice

// PLOT
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

ZN_color = color.blue
E6_color = color.purple
GC_color = color.yellow
long_color = color.blue
short_color = color.red
vwap_color = color.new(color.white, 70)

isZN = syminfo.root == "ZN"
isE6 = syminfo.root == "6E"
// isGC = syminfo.root == "GC"
isGC = syminfo.root == "MGC"

// bar color
barColor =
     isZN and isZNsupportive ? long_color :
     isZN and isZNhostile ? short_color :
     isZN ? color.new(ZN_color, 70) :
     isE6 and isE6supportive ? long_color :
     isE6 and isE6hostile ? short_color :
     isE6 ? color.new(E6_color, 50) :
     isGC and isMacroSupportive ? long_color :
     isGC and isMacroHostile ? short_color :
     isGC ? color.new(GC_color, 70) : na
barcolor(barColor)

// signals
// plot(
//      isGC and isLongSignal ? open : na,
//      style = plot.style_circles,
//      color = long_color,
//      linewidth = 6)
// plot(
//      isGC and isShortSignal ? open : na,
//      style = plot.style_circles,
//      color = short_color,
//      linewidth = 6)
// plotshape(
//      isGC and isLongExit ? open : na,
//      title = "Long Exit",
//      style = shape.xcross,
//      location = location.absolute,
//      color = long_color,
//      size = size.tiny)
// plotshape(
//      isGC and isShortExit ? open : na,
//      title = "Short Exit",
//      style = shape.xcross,
//      location = location.absolute,
//      color = short_color,
//      size = size.tiny)

// vwap


plot(isZN and isBlendedVwap ? znVwap : na, color = vwap_color, style = plot.style_linebr)
plot(isE6 and isBlendedVwap ? e6Vwap : na, color = vwap_color, style = plot.style_linebr)
plot(isGC and isBlendedVwap ? gcVwap : na, color = vwap_color, style = plot.style_linebr)
plot(isZN ? znBlendedVwap : na, color = vwap_color)
plot(isE6 ? e6BlendedVwap : na, color = vwap_color)
plot(isGC ? gcBlendedVwap : na, color = vwap_color)

// ALERT
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

// Event • Context • Value

var string alertMessage = na
alertMessage := na

formattedPrice = str.tostring(math.round_to_mintick(open), "#.00")
formattedProfit = str.tostring(math.round(math.abs(profit / syminfo.mintick)))

// macro supportive
triggerMacroSupportive =
     isGC
     and isMacroSupportivePersistent
     and not isMacroSupportivePersistent[1]

if triggerMacroSupportive and not barstate.isconfirmed
    alertMessage := "Macro • Rates and Dollar • Bullish"

// macro hostile
triggerMacroHostile =
     isGC
     and isMacroHostilePersistent
     and not isMacroHostilePersistent[1]

if triggerMacroHostile and not barstate.isconfirmed
    alertMessage := "Macro • Rates and Dollar • Bearish"

// entry long
if isGC and isLongSignal and not barstate.isconfirmed
    alertMessage := "Entry • Long • " + formattedPrice

// entry short
if isGC and isShortSignal and not barstate.isconfirmed
    alertMessage := "Entry • Short • " + formattedPrice

// exit long
if isGC and isLongExit and not barstate.isconfirmed
    profitMessage = (profit > 0 ? "Profit " : "Loss ") + formattedProfit + " ticks"
    alertMessage := "Exit • Long • " + profitMessage

// exit short
if isGC and isShortExit and not barstate.isconfirmed
    profitMessage = (profit > 0 ? "Profit " : "Loss ") + formattedProfit + " ticks"
    alertMessage := "Exit • Short • " + profitMessage

// alert
if not na(alertMessage)
    alert(alertMessage, alert.freq_once_per_bar)