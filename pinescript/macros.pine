//@version=6
indicator(
    "ZN • 6E • GC",
    overlay = true,
    max_bars_back = 2000)

// INPUT
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

ZN_LOOKBACK = 5
E6_LOOKBACK = 5
GC_LOOKBACK = 5

GC_PULLBACK_TICKS = 20

// DATA
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

isZN = syminfo.root == "ZN"
isE6 = syminfo.root == "6E"
isGC = syminfo.root == "MGC"

ZN_high = request.security("CBOT:ZN1!", timeframe.period, high)
ZN_low = request.security("CBOT:ZN1!", timeframe.period, low)
E6_high = request.security("CME:6E1!", timeframe.period, high)
E6_low = request.security("CME:6E1!", timeframe.period, low)
GC_high = request.security("COMEX_MINI:MGC1!", timeframe.period, high)
GC_low = request.security("COMEX_MINI:MGC1!", timeframe.period, low)

ZN_tick_size = request.security("CBOT:ZN1!", timeframe.period, syminfo.mintick)
E6_tick_size = request.security("CME:6E1!", timeframe.period, syminfo.mintick)
GC_tick_size = request.security("COMEX_MINI:MGC1!", timeframe.period, syminfo.mintick)

// MACRO STATE
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

// 1 = supportive, -1 = hostile
var ZN_state = 1
var E6_state = 1

ZN_high_tick_change = math.round((ZN_high - ZN_high[1]) / ZN_tick_size)
ZN_low_tick_change = math.round((ZN_low - ZN_low[1]) / ZN_tick_size)
ZN_bar_score = ZN_high_tick_change + ZN_low_tick_change

E6_high_tick_change = math.round((E6_high - E6_high[1]) / E6_tick_size)
E6_low_tick_change = math.round((E6_low - E6_low[1]) / E6_tick_size)
E6_bar_score = E6_high_tick_change + E6_low_tick_change

ZN_total_score = math.sum(ZN_bar_score, ZN_LOOKBACK)
E6_total_score = math.sum(E6_bar_score, E6_LOOKBACK)

ZN_state :=
     ZN_total_score > 0 ? 1 :
     ZN_total_score < 0 ? -1 :
     ZN_state[1]

E6_state :=
     E6_total_score > 0 ? 1 :
     E6_total_score < 0 ? -1 :
     E6_state[1]

isMacroLong = ZN_state == 1 and E6_state == 1
isMacroShort = ZN_state == -1 and E6_state == -1
isMacroMixed = not isMacroLong and not isMacroShort

// GC LOGIC
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

GC_recent_high = ta.highest(GC_high[1], GC_LOOKBACK)
GC_recent_low = ta.lowest(GC_low[1], GC_LOOKBACK)

GC_pullback_ticks = math.round((GC_recent_high - open) / GC_tick_size)
GC_bounce_ticks = math.round((open - GC_recent_low) / GC_tick_size)

GC_hasPulledBackForLong = GC_pullback_ticks > GC_PULLBACK_TICKS
GC_hasBouncedForShort = GC_bounce_ticks > GC_PULLBACK_TICKS

GC_lastBarBouncedForLong =
     GC_high[1] > GC_high[2] and
     GC_low[1] > GC_low[2]

GC_lastBarFailedForShort =
     GC_high[2] > GC_high[1] and
     GC_low[2] > GC_low[1]

GC_isLongSignal =
     isMacroLong and
     GC_hasPulledBackForLong and
     GC_lastBarBouncedForLong

GC_isShortSignal =
     isMacroShort and
     GC_hasBouncedForShort and
     GC_lastBarFailedForShort

// PLOT
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

ZN_color = color.blue
E6_color = color.purple
GC_color = color.yellow
long_color = color.blue
short_color = color.red

barColor =
     isZN and ZN_state == 1 ? long_color :
     isZN and ZN_state == -1 ? short_color :
     isZN ? color.new(ZN_color, 70) :

     isE6 and E6_state == 1 ? long_color :
     isE6 and E6_state == -1 ? short_color :
     isE6 ? color.new(E6_color, 70) :

     isGC and GC_isLongSignal ? long_color :
     isGC and GC_isShortSignal ? short_color :
     isGC ? GC_color : na

barcolor(barColor)