//@version=6
indicator(
    "ZN • 6E • GC",
    overlay = true,
    max_bars_back = 2000)

// INPUT
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////





// SESSION CONTROL
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

// official market open for new futures session
marketOpenTime = "1800-1801"
marketCloseTime = "1659-1700"
isNewSession = not na(time(timeframe.period, marketOpenTime, "America/New_York"))
isMarketClosing = not na(time(timeframe.period, marketCloseTime, "America/New_York"))

// no trades allowed during 10 min market warmup, close open positions 1 min before market close
inSessionTimes = "1810-1659"
isInSession = not na(time(timeframe.period, inSessionTimes, "America/New_York"))

// blend vwap from previous to new on session start for 60 minutes, prevents discontinuity at session start
blendedVwapMinutes = 120
isBlendedVwapTimes = "1800-2000"
isBlendedVwap = not na(time(timeframe.period, isBlendedVwapTimes, "America/New_York"))

// MACRO REGIME
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

// 1 = supportive, 0 = neutral, -1 = hostile

ZN_SYMBOL = "CBOT:ZN1!"
E6_SYMBOL = "CME:6E1!"

ZN_open = request.security(
     ZN_SYMBOL,
     timeframe.period,
     open)

E6_open = request.security(
     E6_SYMBOL,
     timeframe.period,
     open)

calc_blended_vwap() =>
    current = ta.vwap(open)
    prev = ta.valuewhen(isMarketClosing, current, 0)
    sessionStartTime = ta.valuewhen(isNewSession, time, 0)
    elapsedMinutes = (time - sessionStartTime) / 60000.0
    c = math.min(1.0, elapsedMinutes / float(blendedVwapMinutes))
    prev + c * (current - prev)

ZN_blended_vwap = request.security(
     ZN_SYMBOL,
     timeframe.period,
     calc_blended_vwap())

E6_blended_vwap = request.security(
     E6_SYMBOL,
     timeframe.period,
     calc_blended_vwap())

isZNsupportive = ZN_open > ZN_blended_vwap
isZNhostile = ZN_open < ZN_blended_vwap

isE6supportive = E6_open > E6_blended_vwap
isE6hostile = E6_open < E6_blended_vwap

isMacroSupportive = isZNsupportive and isE6supportive
isMacroHostile = isZNhostile and isE6hostile
isMacroNuetral = not isMacroSupportive and not isMacroHostile

// GC LOGIC
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

MACRO_ENTRY_PERSISTENCE_BARS = 3
MACRO_EXIT_PERSISTENCE_BARS = 5
GC_LOOKBACK = 5
GC_POSITION_THRESHOLD = 0.60

var bool isLongTradeActive = false
var bool isShortTradeActive = false

isMacroSupportivePersistent = math.sum(isMacroSupportive ? 1 : 0, MACRO_ENTRY_PERSISTENCE_BARS) == MACRO_ENTRY_PERSISTENCE_BARS
isMacroHostilePersistent = math.sum(isMacroHostile ? 1 : 0, MACRO_ENTRY_PERSISTENCE_BARS) == MACRO_ENTRY_PERSISTENCE_BARS

isMacroNotSupportivePersistent = math.sum(not isMacroSupportive ? 1 : 0, MACRO_EXIT_PERSISTENCE_BARS) == MACRO_EXIT_PERSISTENCE_BARS
isMacroNotHostilePersistent = math.sum(not isMacroHostile ? 1 : 0, MACRO_EXIT_PERSISTENCE_BARS) == MACRO_EXIT_PERSISTENCE_BARS

GC_recent_high = ta.highest(high[1], GC_LOOKBACK)
GC_recent_low = ta.lowest(low[1], GC_LOOKBACK)
GC_range = GC_recent_high - GC_recent_low
GC_position = (open - GC_recent_low) / GC_range

isGCPositionValidForLong = true // GC_position > GC_POSITION_THRESHOLD
isGCPositionValidForShort = true // GC_position < (1 - GC_POSITION_THRESHOLD)

isLongSignal =
     isGCPositionValidForLong
     and not isLongTradeActive
     and not isShortTradeActive
     and isMacroSupportivePersistent
     and not isMacroSupportivePersistent[1]
     and isInSession

isShortSignal =
     isGCPositionValidForShort
     and not isLongTradeActive
     and not isShortTradeActive
     and isMacroHostilePersistent
     and not isMacroHostilePersistent[1]
     and isInSession

isLongExit =
     isLongTradeActive
     and (
          not isInSession
          or (
               isMacroNotSupportivePersistent
               and not isMacroNotSupportivePersistent[1]
          )
     )

isShortExit =
     isShortTradeActive
     and (
          not isInSession
          or (
               isMacroNotHostilePersistent
               and not isMacroNotHostilePersistent[1]
          )
     )

// update stae
if isLongSignal
    isLongTradeActive := true
    isShortTradeActive := false
if isShortSignal
    isLongTradeActive := false
    isShortTradeActive := true
if isLongExit
    isLongTradeActive := false
if isShortExit
    isShortTradeActive := false

// PLOT
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

ZN_color = color.blue
E6_color = color.purple
GC_color = color.yellow
long_color = color.blue
short_color = color.red

isZN = syminfo.root == "ZN"
isE6 = syminfo.root == "6E"
isGC = syminfo.root == "MGC"

// bar colors (ZN + E6 only)
barColor =
     isZN and isZNsupportive ? long_color :
     isZN and isZNhostile ? short_color :
     isZN ? color.new(ZN_color, 70) :

     isE6 and isE6supportive ? long_color :
     isE6 and isE6hostile ? short_color :
     isE6 ? color.new(E6_color, 70) :

     isGC and isMacroSupportive ? long_color :
     isGC and isMacroHostile ? short_color :
     isGC ? color.new(GC_color, 70) : na

barcolor(barColor)

plot(
     isGC and isLongSignal ? open : na,
     style = plot.style_circles,
     color = long_color,
     linewidth = 6)

plot(
     isGC and isShortSignal ? open : na,
     style = plot.style_circles,
     color = short_color,
     linewidth = 6)

plotshape(
     isGC and isLongExit ? open : na,
     title = "Long Exit",
     style = shape.xcross,
     location = location.absolute,
     color = long_color,
     size = size.tiny)

plotshape(
     isGC and isShortExit ? open : na,
     title = "Short Exit",
     style = shape.xcross,
     location = location.absolute,
     color = short_color,
     size = size.tiny)

// vwap
ZN_vwap = request.security(
     ZN_SYMBOL,
     timeframe.period,
     ta.vwap(open))
E6_vwap = request.security(
     E6_SYMBOL,
     timeframe.period,
     ta.vwap(open))
GC_vwap = ta.vwap(open)

plot(isZN and isBlendedVwap ? ZN_vwap : na, color = color.new(color.white, 90), linewidth = 1)
plot(isE6 and isBlendedVwap ? E6_vwap : na, color = color.new(color.white, 90), linewidth = 1)
plot(isZN ? ZN_blended_vwap : na, color = color.new(color.white, 70), linewidth = 1)
plot(isE6 ? E6_blended_vwap : na, color = color.new(color.white, 70), linewidth = 1)
plot(isGC ? GC_vwap : na, color = color.new(color.white, 70), linewidth = 1)