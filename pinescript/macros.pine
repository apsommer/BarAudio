//@version=6
indicator(
    "ZN • 6E • MGC",
    overlay = true,
    max_bars_back = 2000)

// INPUT
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////





// SESSION CONTROL
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

// official market open for new futures session
marketOpenTime = "1800-1801"
marketCloseTime = "1659-1700"
isNewSession = not na(time(timeframe.period, marketOpenTime, "America/New_York"))
isMarketClosing = not na(time(timeframe.period, marketCloseTime, "America/New_York"))

// no trades allowed during 10 min market warmup, close open positions 1 min before market close
inSessionTimes = "1810-1659"
isInSession = not na(time(timeframe.period, inSessionTimes, "America/New_York"))

// blend vwap from previous to new on session start for 60 minutes, prevents discontinuity at session start
blendedVwapMinutes = 90
isBlendedVwapTimes = "1800-1930"
isBlendedVwap = not na(time(timeframe.period, isBlendedVwapTimes, "America/New_York"))
calc_blended_vwap() =>
    current = ta.vwap(open)
    prev = ta.valuewhen(isMarketClosing, current, 0)
    sessionStartTime = ta.valuewhen(isNewSession, time, 0)
    elapsedMinutes = (time - sessionStartTime) / 60000.0
    c = math.min(1.0, elapsedMinutes / float(blendedVwapMinutes))
    prev + c * (current - prev)

// MACRO REGIME
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

// 1 = supportive, 0 = neutral, -1 = hostile

ZN_SYMBOL = "CBOT:ZN1!"
E6_SYMBOL = "CME:6E1!"

ZN_open = request.security(
     ZN_SYMBOL,
     timeframe.period,
     open)

E6_open = request.security(
     E6_SYMBOL,
     timeframe.period,
     open)

ZN_blended_vwap = request.security(
     ZN_SYMBOL,
     timeframe.period,
     calc_blended_vwap())

E6_blended_vwap = request.security(
     E6_SYMBOL,
     timeframe.period,
     calc_blended_vwap())

isZNsupportive = ZN_open > ZN_blended_vwap
isZNhostile = ZN_open < ZN_blended_vwap

isE6supportive = E6_open > E6_blended_vwap
isE6hostile = E6_open < E6_blended_vwap

// 1 = supportive, 0 = neutral, -1 = hostile
isMacroSupportive = isZNsupportive and isE6supportive
isMacroHostile = isZNhostile and isE6hostile
isMacroNuetral = not isMacroSupportive and not isMacroHostile

// MGC LOGIC
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

MGC_SYMBOL = "COMEX_MINI:MGC1!"

MACRO_ENTRY_PERSISTENCE_BARS = 2
MACRO_EXIT_PERSISTENCE_BARS = 1

var int macroPersistentState = 0
var int macroSupportiveCount = 0
var int macroHostileCount = 0
var int macroNotSupportiveCount = 0
var int macroNotHostileCount = 0
var bool isLongTradeActive = false
var bool isShortTradeActive = false

// count consecutive regime bars
macroSupportiveCount := isMacroSupportive ? macroSupportiveCount[1] + 1 : 0
macroHostileCount := isMacroHostile ? macroHostileCount[1] + 1 : 0
macroNotSupportiveCount := isMacroNuetral or isMacroHostile ? macroNotSupportiveCount + 1 : 0
macroNotHostileCount := isMacroNuetral or isMacroSupportive ? macroNotHostileCount + 1 : 0

// entry into supportive / hostile
if macroPersistentState == 0 and macroSupportiveCount > MACRO_ENTRY_PERSISTENCE_BARS
    macroPersistentState := 1
if macroPersistentState == 0 and macroHostileCount > MACRO_ENTRY_PERSISTENCE_BARS
    macroPersistentState := -1

// exit back to neutral
if macroPersistentState == 1 and macroNotSupportiveCount > MACRO_EXIT_PERSISTENCE_BARS
    macroPersistentState := 0
if macroPersistentState == -1 and macroNotHostileCount > MACRO_EXIT_PERSISTENCE_BARS
    macroPersistentState := 0

// persistence in regime
isMacroSupportivePersistent = macroPersistentState == 1
isMacroHostilePersistent = macroPersistentState == -1
isMacroNuetralPersistent = macroPersistentState == 0

// 6E must be trending up over the lookback period
E6_LOOKBACK = 10
E6_recent_high = request.security(E6_SYMBOL, timeframe.period, ta.highest(high[1], E6_LOOKBACK))
E6_recent_low = request.security(E6_SYMBOL, timeframe.period, ta.lowest(low[1], E6_LOOKBACK))
E6_range = E6_recent_high - E6_recent_low
E6_position = (E6_open - E6_recent_low) / E6_range
isE6PositionValidForLong = E6_position > 0.50
isE6PositionValidForShort = E6_position < 0.50

isLongSignal =
     isE6PositionValidForLong
     and not isLongTradeActive
     and not isShortTradeActive
     and isMacroSupportivePersistent
     and isInSession

isShortSignal =
     isE6PositionValidForShort
     and not isLongTradeActive
     and not isShortTradeActive
     and isMacroHostilePersistent
     and isInSession

isLongExit =
     isLongTradeActive
     and (not isInSession or isMacroNuetralPersistent)

isShortExit =
     isShortTradeActive
     and (not isInSession or isMacroNuetralPersistent)

// update state
if isLongSignal
    isLongTradeActive := true
    isShortTradeActive := false
if isShortSignal
    isLongTradeActive := false
    isShortTradeActive := true
if isLongExit
    isLongTradeActive := false
if isShortExit
    isShortTradeActive := false

// PLOT
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

ZN_color = color.blue
E6_color = color.purple
MGC_color = color.yellow
long_color = color.blue
short_color = color.red

isZN = syminfo.root == "ZN"
isE6 = syminfo.root == "6E"
isMGC = syminfo.root == "MGC"

// bar color
barColor =
     isZN and isZNsupportive ? long_color :
     isZN and isZNhostile ? short_color :
     isZN ? color.new(ZN_color, 70) :
     isE6 and isE6supportive ? long_color :
     isE6 and isE6hostile ? short_color :
     isE6 ? color.new(E6_color, 70) :
     isMGC and isMacroSupportive ? long_color :
     isMGC and isMacroHostile ? short_color :
     isMGC ? color.new(MGC_color, 70) : na
barcolor(barColor)

// signals
plot(
     isMGC and isLongSignal ? open : na,
     style = plot.style_circles,
     color = long_color,
     linewidth = 6)
plot(
     isMGC and isShortSignal ? open : na,
     style = plot.style_circles,
     color = short_color,
     linewidth = 6)
plotshape(
     isMGC and isLongExit ? open : na,
     title = "Long Exit",
     style = shape.xcross,
     location = location.absolute,
     color = long_color,
     size = size.tiny)
plotshape(
     isMGC and isShortExit ? open : na,
     title = "Short Exit",
     style = shape.xcross,
     location = location.absolute,
     color = short_color,
     size = size.tiny)

// vwap
ZN_vwap = request.security(
     ZN_SYMBOL,
     timeframe.period,
     ta.vwap(open))
E6_vwap = request.security(
     E6_SYMBOL,
     timeframe.period,
     ta.vwap(open))
MGC_blended_vwap = request.security(
     MGC_SYMBOL,
     timeframe.period,
     calc_blended_vwap())
MGC_vwap = ta.vwap(open)

plot(isZN and isBlendedVwap ? ZN_vwap : na, color = color.new(color.white, 90), linewidth = 1, style = plot.style_linebr)
plot(isE6 and isBlendedVwap ? E6_vwap : na, color = color.new(color.white, 90), linewidth = 1, style = plot.style_linebr)
plot(isMGC and isBlendedVwap ? MGC_vwap : na, color = color.new(color.white, 90), linewidth = 1, style = plot.style_linebr)
plot(isZN ? ZN_blended_vwap : na, color = color.new(color.white, 70), linewidth = 1)
plot(isE6 ? E6_blended_vwap : na, color = color.new(color.white, 70), linewidth = 1)
plot(isMGC ? MGC_blended_vwap : na, color = color.new(color.white, 70), linewidth = 1)