//@version=6
strategy(
    "ZN • 6E • GC",
    overlay = true,
    max_bars_back = 2000,
    calc_on_every_tick = false,

    process_orders_on_close = true,
    initial_capital = 50000, // qty 1 -> needs to be greater than close of first bar * 10
    default_qty_type = strategy.fixed,
    default_qty_value = 1,
    commission_type = strategy.commission.cash_per_contract,
    commission_value = 1.35
)

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

// DATA
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

ZN_SYMBOL = "CBOT:ZN1!"
E6_SYMBOL = "CME:6E1!"
GC_SYMBOL = "COMEX_MINI:MGC1!"

ticker = ticker.standard(syminfo.tickerid)
isZN = str.contains(ticker, "ZN1!")
isE6 = str.contains(ticker, "6E1!")
isGC = str.contains(ticker, "MGC1!")

ZN_LOOKBACK = 85
E6_LOOKBACK = 55
GC_LOOKBACK = 30
GC_EARLY_ALIGNMENT_MIN_BARS  = 1 // wait for stability
GC_EARLY_ALIGNMENT_MAX_BARS = 10 // ensure move is early

// SESSION CONTROL
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

// asia: 1810-0200
// london: 0300-1130
// TRANSITION: 0400-0900 end of london, pre-US
// us: 0930-1600

// session windows (entry allowed)
inSessionTimes = "1815-0859" // "0915-1559"
isInSession = not na(time(timeframe.period, inSessionTimes, "America/New_York"))

// session closing (exit)
sessionClosingTime = "1659-1700"
isSessionClosing = not na(time(timeframe.period, sessionClosingTime, "America/New_York"))

// ZN
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

var bool isZNsupportive = false
var bool isZNhostile = false

znOpen = request.security(ZN_SYMBOL, timeframe.period, open)
znVwap = request.security(ZN_SYMBOL, timeframe.period, ta.vwap(hlc3))

znHigherHigh = request.security(ZN_SYMBOL, timeframe.period, high > ta.highest(high[1], ZN_LOOKBACK))
znLowerLow = request.security(ZN_SYMBOL, timeframe.period, ta.lowest(low[1], ZN_LOOKBACK) > low)

znAbove = znOpen > znVwap
znBelow = znVwap > znOpen

isZNsupportive :=
     znHigherHigh and znAbove ? true :
     znLowerLow and znBelow ? false :
     znLowerLow and znAbove ? false :
     znHigherHigh and znBelow ? false :
     isZNsupportive[1]

isZNhostile :=
     znLowerLow  and znBelow ? true :
     znHigherHigh and znAbove ? false :
     znHigherHigh and znBelow ? false :
     znLowerLow  and znAbove ? false :
     isZNhostile[1]

isZNneutral = not isZNsupportive and not isZNhostile

// 6E
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

var bool isE6supportive = false
var bool isE6hostile = false

e6Open = request.security(E6_SYMBOL, timeframe.period, open)
e6Vwap = request.security(E6_SYMBOL, timeframe.period, ta.vwap(hlc3))

e6HigherHigh = request.security(E6_SYMBOL, timeframe.period, high > ta.highest(high[1], E6_LOOKBACK))
e6LowerLow = request.security(E6_SYMBOL, timeframe.period, ta.lowest(low[1], E6_LOOKBACK) > low)

e6Above = e6Open > e6Vwap
e6Below = e6Vwap > e6Open

isE6supportive :=
     e6HigherHigh and e6Above ? true :
     e6LowerLow  and e6Below ? false :
     e6LowerLow  and e6Above ? false :
     e6HigherHigh and e6Below ? false :
     isE6supportive[1]

isE6hostile :=
     e6LowerLow  and e6Below ? true :
     e6HigherHigh and e6Above ? false :
     e6HigherHigh and e6Below ? false :
     e6LowerLow  and e6Above ? false :
     isE6hostile[1]

// MACRO REGIME
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

// stability
macroSupportCount = math.sum(isZNsupportive and isE6supportive ? 1 : 0, 3)
macroHostileCount = math.sum(isZNhostile and isE6hostile ? 1 : 0, 3)

isMacroSupportive = macroSupportCount > 1
isMacroHostile = macroHostileCount > 1
isMacroNeutral = not isMacroSupportive and not isMacroHostile

isLongMacroBroken = not isZNsupportive or not isE6supportive
isShortMacroBroken = not isZNhostile or not isE6hostile

// GC LOGIC
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

var int gcSupportiveBars = 0
var int gcHostileBars = 0

gcAvg = ta.sma(open, GC_LOOKBACK)
gcVwap = ta.vwap(hlc3)
gcSlope = gcAvg - gcAvg[1]

// trend
isGCsupportive = open > gcAvg
isGChostile = not isGCsupportive

// count trend bars
gcSupportiveBars := isGCsupportive ? gcSupportiveBars[1] + 1 : 0
gcHostileBars := isGChostile ? gcHostileBars[1] + 1 : 0

// early in new, stable trend
isGCsupportiveEarly =
     isGCsupportive
     and gcSupportiveBars > GC_EARLY_ALIGNMENT_MIN_BARS
     and GC_EARLY_ALIGNMENT_MAX_BARS >= gcSupportiveBars
isGChostileEarly =
     isGChostile
     and gcHostileBars > GC_EARLY_ALIGNMENT_MIN_BARS
     and GC_EARLY_ALIGNMENT_MAX_BARS >= gcHostileBars

// GC TRADE
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

varip bool isBarStable = false
var bool isLongTradeActive = false
var bool isShortTradeActive = false
var float entryPrice = na
var float exitPrice = na
var float profit = na

// calc_on_every_tick has ridiculous problem of pulling previous bar values into this bar just for the very first tick
// creates ghost signals that are not accurate, bar is stable on second tick and later
// additional related problem: first tick arrives at different time when assets pulled from security()
// znTime = request.security(ZN_SYMBOL, timeframe.period, time)
// e6Time = request.security(E6_SYMBOL, timeframe.period, time)
isBarStable := true
     // not barstate.isrealtime
     // or (
     //      not barstate.isnew
     //      and time == znTime
     //      and time == e6Time
     // )

// entry
isLongEntry =
     isBarStable
     and isInSession
     and not isLongTradeActive
     and not isShortTradeActive
     and open > gcVwap
     and isMacroSupportive
     and isGCsupportiveEarly

isShortEntry =
     isBarStable
     and isInSession
     and not isLongTradeActive
     and not isShortTradeActive
     and gcVwap > open
     and isMacroHostile
     and isGChostileEarly

if isLongEntry
    isLongTradeActive := true
    isShortTradeActive := false
    entryPrice := close

if isShortEntry
    isLongTradeActive := false
    isShortTradeActive := true
    entryPrice := close

// exit
isLongExit =
     isBarStable
     and isLongTradeActive
     and (
        isLongMacroBroken
        or not isInSession
     )

isShortExit =
     isBarStable
     and isShortTradeActive
     and (
        isShortMacroBroken
        or not isInSession
     )

if isLongExit
    isLongTradeActive := false
    exitPrice := close
    profit := exitPrice - entryPrice

if isShortExit
    isShortTradeActive := false
    exitPrice := close
    profit := entryPrice - exitPrice

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

// STRATEGY
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

if isGC and isLongEntry
    strategy.entry("long", strategy.long)
if isGC and isShortEntry
    strategy.entry("short", strategy.short)
if isGC and isLongExit
    strategy.close("long")
if isGC and isShortExit
    strategy.close("short")

// PLOT
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

// colors
ZN_color = color.purple
E6_color = color.teal
GC_color = color.yellow
long_color = color.blue
short_color = color.red
win_color = color.green
loss_color = color.red
session_color = color.gray
line_color = color.white

// transparency
bar_transparency = 50
signal_tranparency = 0
line_transparency = 80
bg_macro_transparency = 90
bg_session_transparency = 50

line_width = 2

// bar color
barColor =
     isZN and isZNsupportive ? color.new(long_color, bar_transparency) :
     isZN and isZNhostile ? color.new(short_color, bar_transparency) :
     isZN ? color.new(ZN_color, bar_transparency) :
     isE6 and isE6supportive ? color.new(long_color, bar_transparency) :
     isE6 and isE6hostile ? color.new(short_color, bar_transparency) :
     isE6 ? color.new(E6_color, bar_transparency) :
     not isInSession ? color.new(session_color, bar_transparency) :
     isGC and isGCsupportive ? color.new(long_color, bar_transparency) :
     isGC and isGChostile ? color.new(short_color, bar_transparency) :
     isGC ? color.new(GC_color, bar_transparency) : na
barcolor(barColor)

// background
usaOpeningTime = "0900-0901"
isUsaMarketOpening = not na(time(timeframe.period, usaOpeningTime, "America/New_York"))
bgcolor(
     isSessionClosing or isUsaMarketOpening ? color.new(session_color, bg_session_transparency) :
     isGC and isMacroSupportive ? color.new(long_color, bg_macro_transparency) :
     isGC and isMacroHostile ? color.new(short_color, bg_macro_transparency) : na
)

// entry
plot(
     isGC and isLongEntry ? entryPrice : na,
     style = plot.style_circles,
     color = color.new(long_color, signal_tranparency),
     linewidth = 5)
plot(
     isGC and isShortEntry ? entryPrice : na,
     style = plot.style_circles,
     color = color.new(short_color, signal_tranparency),
     linewidth = 5)

// exit
exit_color =
     profit >= 0 ? color.new(win_color, signal_tranparency) :
     color.new(loss_color, signal_tranparency)
plotshape(
     isGC and (isLongExit or isShortExit) ? exitPrice : na,
     title = "Long Exit",
     style = shape.xcross,
     location = location.absolute,
     color = exit_color,
     size = size.tiny)

// lines
plot(isZN ? znVwap : na, color = color.new(session_color, line_transparency), linewidth = line_width)
plot(isE6 ? e6Vwap : na , color = color.new(session_color, line_transparency), linewidth = line_width)
plot(isGC ? gcVwap : na, color = color.new(session_color, line_transparency), linewidth = line_width)
plot(isGC ? gcAvg : na , color = color.new(GC_color, line_transparency), linewidth = line_width)

// ALERT
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

// Event • Direction/State • Context • Value

var string alertMessage = na
var int lastMacroAlertBar = 0
var int lastMacroAlertDirection = 0 // -1 hostile, 0 nuetral, 1 supportive

// reset alert container
alertMessage := na

// cooldown since last macro alert
MACRO_COOLDOWN_BARS = 15
barsSinceMacro = bar_index - lastMacroAlertBar
isMacroCooldownPassed = barsSinceMacro >= MACRO_COOLDOWN_BARS

// beautify price
formattedPrice = str.tostring(math.round_to_mintick(open), "#.00")

// calculate p&l in ticks (protect user financial implications spoken aloud)
tickSize = syminfo.mintick
longTicks = math.round((open - entryPrice) / tickSize)
shortTicks = math.round((entryPrice - open) / tickSize)

// calculate percent change on ZN (match tradingview watchlist)
znPrevClose = request.security(ZN_SYMBOL, "D", close[1])
znSessionPercent = (znOpen - znPrevClose) / znPrevClose * 100.0
formattedZnSessionPercent =
     znSessionPercent == 0 ? "0.00%" :
     znSessionPercent > 0 ? "+" + str.tostring(math.abs(znSessionPercent), "0.00") + "%" :
     "-" + str.tostring(math.abs(znSessionPercent), "0.00") + "%"

// macro supportive
triggerMacroSupportive =
     isGC
     and isMacroSupportive
     and isMacroSupportive[1]
     and isMacroCooldownPassed
     and lastMacroAlertDirection != 1
if triggerMacroSupportive
    if na(alertMessage)
        alertMessage := "Macro Supportive • Treasuries " + formattedZnSessionPercent + " • Dollar falling"
        lastMacroAlertBar := bar_index
        lastMacroAlertDirection := 1

// macro hostile
triggerMacroHostile =
     isGC
     and isMacroHostile
     and isMacroHostile[1]
     and isMacroCooldownPassed
     and lastMacroAlertDirection != -1
if triggerMacroHostile
    if na(alertMessage)
        alertMessage := "Macro Hostile • Treasuries " + formattedZnSessionPercent + " • Dollar rising"
        lastMacroAlertBar := bar_index
        lastMacroAlertDirection := -1

// entry
if isGC and isLongEntry
    if na(alertMessage)
        alertMessage := "Entry • Long • " + formattedPrice
if isGC and isShortEntry
    if na(alertMessage)
        alertMessage := "Entry • Short • " + formattedPrice

// exit long
if isGC and isLongExit
    if na(alertMessage)
        isYieldRising = isZNhostile
        isDollarStronger = isE6hostile
        exitReason =
             isYieldRising and not isDollarStronger ? "Yields rising" :
             isDollarStronger and not isYieldRising ? "Dollar rising" : "Macro alignment lost"
        exitPnL =
             longTicks >= 0 ? "+" + str.tostring(longTicks) + " ticks" :
             "-" + str.tostring(math.abs(longTicks)) + " ticks"
        alertMessage := "Exit • Long • " + exitReason + " • " + exitPnL

// exit short
if isGC and isShortExit
    if na(alertMessage)
        isTreasuriesStronger = isZNsupportive
        isDollarWeaker = isE6supportive
        exitReason =
             isTreasuriesStronger and not isDollarWeaker ? "Treasuries rising" :
             isDollarWeaker and not isTreasuriesStronger ? "Dollar falling" : "Macro alignment lost"
        exitPnL =
             shortTicks >= 0 ? "+" + str.tostring(shortTicks) + " ticks" :
             "-" + str.tostring(math.abs(shortTicks)) + " ticks"
        alertMessage := "Exit • Short • " + exitReason + " • " + exitPnL

// alert
if not na(alertMessage)
    alert(alertMessage, alert.freq_once_per_bar)