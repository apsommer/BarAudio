//@version=6
indicator(
    "SIL engine",
    overlay = true,
    max_boxes_count = 500,
    max_bars_back = 2000)

// INPUT
////////////////////////////////////////////////////////////////////////////////////////////////////

// higher timeframe
HTF_TIMEFRAME = "60" // minutes
HTF_SMA_LENGTH = 50

// momentum / velocity
CASCADE_VELOCITY_BARS = 18
STRUCTURE_DISPLACEMENT_BARS = 20
STRUCTURE_BASELINE_BARS = 120
SMOOTH_BARS = 6
ACCELERATION_BARS = 4
ACCELERATION_PERCENT = 12.0

// cascade detection
VELOCITY_SPIKE_RATIO = 3.6
RANGE_EXPANSION_RATIO = 3.0
BAR_STRENGTH_RATIO = 0.80
CASCADE_LOOKBACK = 22

// cascade exhaustion / reversal readiness
STALLED_BARS = 3
VELOCITY_NORMALIZATION_RATIO = 1.0
HIGHER_WICK_PERCENT = 0.60

// mgc context (not gating)
MGC_SYMBOL = "MGC1!"
MGC_MOMENTUM_BARS = 20

// INIT
////////////////////////////////////////////////////////////////////////////////////////////////////

// lifecycle
var bool isCascadeActive = false
var bool isReversalReady = false
var bool isLongActive = false
var int cascadeStartBar = na
var float cascadeLow = na
var float cascadeHigh = na
var int stalledCount = 0
var bool isStalled = false
var int entryBar = na
var float entryPrice = na
var bool isMgcConfirming = false
var bool isSilverLeading = false

// current velocity
currentVelocity = math.abs(close - close[1])
smaCurrentVelocity = ta.sma(currentVelocity, CASCADE_VELOCITY_BARS)

// structure velocity, momentum, acceleration
structureVelocity = math.abs(close - close[STRUCTURE_DISPLACEMENT_BARS]) / STRUCTURE_DISPLACEMENT_BARS
smaStructureVelocity = ta.sma(structureVelocity, STRUCTURE_BASELINE_BARS)
rawMomentumPercent = smaStructureVelocity > 0 ? (structureVelocity / smaStructureVelocity - 1.0) * 100.0 : 0
momentum = ta.sma(rawMomentumPercent, SMOOTH_BARS)
acceleration = momentum - momentum[ACCELERATION_BARS]

// bar range
barRange = high - low
smaBarRange = ta.sma(barRange, CASCADE_VELOCITY_BARS)
downBody = open - close
upBody = close - open
bodyRangeRatioDown = barRange > 0 ? downBody / barRange : 0
bodyRangeRatioUp = barRange > 0 ? upBody / barRange : 0
higherWickPercent = barRange > 0 ? (close - low) / barRange : 0



















