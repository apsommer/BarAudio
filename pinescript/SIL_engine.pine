//@version=6
indicator(
    "SIL engine",
    overlay = true,
    max_boxes_count = 500,
    max_bars_back = 2000)

// INPUT
////////////////////////////////////////////////////////////////////////////////////////////////////

PRE_CASCADE_LOOKBACK = 45
MIN_CASCADE_SIZE_ABSOLUTE = 0.6

ENTRY_PERCENT = 20
STOP_LOSS_PERCENT = 80
TAKE_PROFIT_PERCENT = 80

// lifecycle
var float cascadeHigh = na
var float cascadeLow = na
var bool isTradeActive = false
var float entryPrice = na

// CASCADE
////////////////////////////////////////////////////////////////////////////////////////////////////

// lowest low in lookback period
isPreCascadeDropping = ta.lowest(low[1], PRE_CASCADE_LOOKBACK) > low

// bar size is large
isLargeCascadeBar = high - low > MIN_CASCADE_SIZE_ABSOLUTE

triggerCascade =
     isPreCascadeDropping
     and isLargeCascadeBar

if triggerCascade
    cascadeHigh := high
    cascadeLow := low

plotshape(triggerCascade, style = shape.triangledown, location = location.abovebar, size = size.small, color = color.red)

// SCALP
////////////////////////////////////////////////////////////////////////////////////////////////////

cascadeSize = cascadeHigh - cascadeLow

// enter after retracing portion of cascade from low to high
entryLevel = cascadeLow + cascadeSize * (ENTRY_PERCENT / 100.0)

// stop loss as percent of cascade size
stopLoss = cascadeLow - cascadeSize * (STOP_LOSS_PERCENT / 100.0)

// take profit as percent of cascade size
takeProfit = cascadeLow + cascadeSize * (TAKE_PROFIT_PERCENT / 100.0)

barsSinceCascade = ta.barssince(triggerCascade)

triggerEntry =
     triggerCascade[1]
     and barsSinceCascade == 1

if triggerEntry
    isTradeActive := true
    if low > entryLevel
        entryPrice := low
    if entryLevel > high
        entryPrice := close
    else
        entryPrice := entryLevel

plot(triggerEntry ? entryPrice : na, style = plot.style_circles, linewidth = 3, color = color.blue)

triggerStopLoss =
     isTradeActive
     and stopLoss > low

plot(triggerStopLoss ? stopLoss : na, style = plot.style_circles, linewidth = 3, color = color.red)

triggerTakeProfit =
     isTradeActive
     and high > takeProfit

plot(triggerTakeProfit ? takeProfit : na, style = plot.style_circles, linewidth = 3, color = color.green)

triggerExit = triggerStopLoss or triggerTakeProfit

if triggerExit
    isTradeActive := false

