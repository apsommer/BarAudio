//@version=6
indicator(
    "SIL engine",
    overlay = true,
    max_lines_count = 500,
    max_boxes_count = 500,
    max_bars_back = 2000)

// INPUT
////////////////////////////////////////////////////////////////////////////////////////////////////

CASCADE_LOOKBACK = 60
MIN_CASCADE_MOVE = 0.5
REGIME_MAX_BARS = 120

// lifecycle
var bool isCascadeActive = false
var int cascadeStartBar = na
var float cascadeHigh = na
var float cascadeLow = na
var float cascadeRange = na
var bool isInProbe = false
var float probeLow = na

// CASCADE
////////////////////////////////////////////////////////////////////////////////////////////////////

// detect cascade
avgRange = ta.sma(high - low, 20)

isLargeCascadeBar =
     (high - low) > avgRange * 2
     and (high - low) > MIN_CASCADE_MOVE

body = math.abs(close - open)
isBearBody = close < open

isLowestLow = ta.lowest(low, CASCADE_LOOKBACK) == low

triggerCascade =
     isLargeCascadeBar
     and isBearBody
     and isLowestLow

// start regime
if triggerCascade and not isCascadeActive
    isCascadeActive := true
    cascadeHigh := high
    cascadeLow := low
    cascadeRange := high - low
    cascadeStartBar := bar_index

// detect cascade extension BEFORE updating
isExtendingCascade = isCascadeActive and low < cascadeLow

// EXIT
////////////////////////////////////////////////////////////////////////////////////////////////////

triggerExit =
     isInProbe
     and low < probeLow

if triggerExit
    isInProbe := false

plotshape(triggerExit ? probeLow : na, style = shape.xcross, location = location.absolute, color = color.red, size = size.tiny)

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
// extend regime before entry
if isExtendingCascade
    cascadeLow := low
    cascadeRange := cascadeHigh - cascadeLow
    isInProbe := false

// resolve regime
if isCascadeActive and close > cascadeHigh
    isCascadeActive := false
    cascadeHigh := na
    cascadeLow := na
    cascadeRange := na

isRegimeExpired = bar_index > cascadeStartBar + REGIME_MAX_BARS
if isCascadeActive and isRegimeExpired
    isCascadeActive := false
    cascadeHigh := na
    cascadeLow := na
    cascadeRange := na

plotshape(triggerCascade, style = shape.triangledown, location = location.abovebar, color = color.red, size = size.small)
plot(isCascadeActive ? cascadeHigh : na, color = color.orange, linewidth = 2, style = plot.style_linebr)
plot(isCascadeActive ? cascadeLow : na, color = color.red, linewidth = 2, style = plot.style_linebr)

totalMovePercentText = str.tostring(math.round(((high - low) / high) * 100.0, 2)) + "%"
cascadeText = "Downside stop cascade with " + totalMovePercentText + " move."
if triggerCascade
    alert(cascadeText, alert.freq_once_per_bar_close)

// ENTRY
////////////////////////////////////////////////////////////////////////////////////////////////////

repairPosition = (close - cascadeLow) / cascadeRange
isNearCascadeLow = repairPosition < 0.2

triggerEntry =
     isCascadeActive
     and not isInProbe
     and not isExtendingCascade
     and bar_index > cascadeStartBar
     and isNearCascadeLow

if triggerEntry
    isInProbe := true
    probeLow := cascadeLow

plotshape(triggerEntry ? close : na, style = shape.circle, location = location.absolute, color = color.green, size = size.tiny)

