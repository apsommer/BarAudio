//@version=6
indicator(
    "SIL engine",
    overlay = true,
    max_lines_count = 500,
    max_boxes_count = 500,
    max_bars_back = 2000)

// INPUT
////////////////////////////////////////////////////////////////////////////////////////////////////

PRE_CASCADE_LOOKBACK = 60
MIN_CASCADE_SIZE_PERCENT = 0.7

// lifecycle
var bool isCascadeActive = false
var float cascadeHigh = na
var float cascadeLow = na
var float cascadeRange = na
var bool hasStabilized = false
var int cascadeStartBar = na

// CASCADE
////////////////////////////////////////////////////////////////////////////////////////////////////

isPreCascadeDropping = ta.lowest(low[1], PRE_CASCADE_LOOKBACK) > low and ta.lowest(low[2], PRE_CASCADE_LOOKBACK) > low[1]
isLargeCascadeBar = (high - low) / high > MIN_CASCADE_SIZE_PERCENT / 100.0

triggerCascade =
     isPreCascadeDropping
     and isLargeCascadeBar

// start cascade
if triggerCascade and (not isCascadeActive or hasStabilized and close < cascadeLow)
    isCascadeActive := true
    cascadeHigh := high
    cascadeLow := low
    cascadeRange := high - low
    cascadeStartBar := bar_index
    hasStabilized := false

// end cascade
if isCascadeActive and close > cascadeHigh
    isCascadeActive := false
    cascadeHigh := na
    cascadeLow := na
    cascadeRange := na
    cascadeStartBar := na
    hasStabilized := false

if isCascadeActive
    if hasStabilized and close < cascadeLow
        isCascadeActive := false
        cascadeHigh := na
        cascadeLow := na
        cascadeRange := na
        cascadeStartBar := na
        hasStabilized := false

// extend cascade
if isCascadeActive
    cascadeLow := math.min(cascadeLow, low)
    cascadeRange := cascadeHigh - cascadeLow


// plot
plot(isCascadeActive ? cascadeHigh : na, color = color.orange, linewidth = 2, style = plot.style_linebr)
plot(isCascadeActive ? cascadeLow : na, color = color.red, linewidth = 2, style = plot.style_linebr)
plotshape(triggerCascade, style = shape.triangledown, location = location.abovebar, color = color.red, size = size.small)

// STABILIZATION
////////////////////////////////////////////////////////////////////////////////////////////////////

isRepairBar1 = low > low[1] and high > high[1]
isRepairBar2 = low[1] > low[2] and high[1] > high[2]

avgRange = ta.sma(high - low, 5)

isCompressed = isCascadeActive and cascadeRange > avgRange * 2

triggerStabilization =
     isCascadeActive
     and not hasStabilized
     and low > cascadeLow
     and isRepairBar1
     and isRepairBar2
     and isCompressed

if triggerStabilization
    hasStabilized := true

plotshape(triggerStabilization, style = shape.triangleup, location = location.belowbar, color = color.green, size = size.small)

