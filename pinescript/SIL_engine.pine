//@version=6
indicator(
    "SIL engine",
    overlay = true,
    max_boxes_count = 500,
    max_bars_back = 2000)

// INPUT
////////////////////////////////////////////////////////////////////////////////////////////////////

HTF_TOLERANCE = 0.7
PRE_CASCADE_LOOKBACK = 60
MIN_CASCADE_RANGE = 0.4
BEARISH_RANGE_RATIO = 0.6
MIN_VWAP_DISPLACEMENT = 0.6
REPAIR_CONFIRMATION_BARS = 2
TAKE_PROFIT_ORIGIN_PERCENT = 200.0

// lifecycle
var bool isRepairActive = false
var float regimeHigh = na
var float regimeLow = na
var bool isTradeActive = false
var float entryPrice = na
var int tradeStartBar = na
var float tradeHigh = na
var float tradeLow = na
var box tradeBox = na

// HTF FILTER
////////////////////////////////////////////////////////////////////////////////////////////////////

prevDayClose = request.security(syminfo.tickerid, "D", close[1])
isHtfBullish = open > prevDayClose - HTF_TOLERANCE
barcolor(isHtfBullish ? color.new(color.green, 70) : na)

// CASCADE
////////////////////////////////////////////////////////////////////////////////////////////////////

isPreCascadeWeak = ta.lowest(low[1], PRE_CASCADE_LOOKBACK) > low
isLargeCascadeBar = high - low > MIN_CASCADE_RANGE
isBearishClose = high - low > 0 and (high - close) / (high - low) > BEARISH_RANGE_RATIO
isCascadeTrigger = isHtfBullish and isPreCascadeWeak and isLargeCascadeBar and isBearishClose and not isTradeActive
plotshape(isCascadeTrigger, style = shape.triangledown, location = location.abovebar, size = size.small, color = color.red)

if isCascadeTrigger and not isRepairActive
    isRepairActive := true
    regimeHigh := high
    regimeLow := low

if isRepairActive
    regimeLow := math.min(regimeLow, low)

// REPAIR REGIME
////////////////////////////////////////////////////////////////////////////////////////////////////

vwap = ta.vwap(close)
plot(vwap, color = color.orange, linewidth = 1)

isVwapDisplaced = isRepairActive and vwap - regimeLow > MIN_VWAP_DISPLACEMENT
barcolor(isVwapDisplaced ? color.orange : na)

// regime invalidate if price creeps back to regimeHigh without entry
isOriginReclaimed = isRepairActive and high > regimeHigh
if isOriginReclaimed
    isRepairActive := false

triggerEntry =
     isRepairActive
     and isVwapDisplaced
     and low > low[1] and low[1] > low[2]
     and high > high[1] and high[1] > high[2]

if triggerEntry and not isTradeActive

    isRepairActive := false
    isTradeActive := true
    entryPrice := close

    tradeHigh := high
    tradeLow := low
    tradeStartBar := bar_index
    tradeBox := box.new(bar_index, regimeHigh, bar_index, regimeLow, bgcolor = color.new(color.blue, 85), border_color = color.blue)

plot(triggerEntry ? entryPrice : na, style = plot.style_circles, linewidth = 3, color = color.blue)

// TRADE REGIME
////////////////////////////////////////////////////////////////////////////////////////////////////

stopLoss = regimeLow
isStopLoss = isTradeActive and stopLoss > low
takeProfit = regimeLow + (regimeHigh - regimeLow) * TAKE_PROFIT_ORIGIN_PERCENT / 100.0
isTakeProfit = isTradeActive and high > takeProfit

if isTradeActive and not na(tradeBox)

    tradeHigh := math.max(tradeHigh, high)
    tradeLow := math.min(tradeLow, low)

    box.set_right(tradeBox, bar_index)
    box.set_top(tradeBox, tradeHigh)
    box.set_bottom(tradeBox, tradeLow)

if isStopLoss

    isTradeActive := false

    box.set_bgcolor(tradeBox, color.new(color.red, 80))
    box.set_border_color(tradeBox, color.red)
    box.set_top(tradeBox, entryPrice)
    box.set_bottom(tradeBox, stopLoss)

else if isTakeProfit

    isTradeActive := false

    box.set_bgcolor(tradeBox, color.new(color.green, 80))
    box.set_border_color(tradeBox, color.green)
    box.set_top(tradeBox, takeProfit)
    box.set_bottom(tradeBox, entryPrice)
