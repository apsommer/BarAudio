//@version=6
indicator(
    "SIL engine",
    overlay = true,
    max_boxes_count = 500,
    max_bars_back = 2000)

// INPUT
////////////////////////////////////////////////////////////////////////////////////////////////////

// higher timeframe
PREV_DAY_TOLERANCE = 0.25

// cascade
PRE_CASCADE_BARS = 60
CASCADE_BARS = 1
MIN_CASCADE_MOVE = 0.3

// entry
RETRACE_PERCENT = 0.2

// HTF REGIME
////////////////////////////////////////////////////////////////////////////////////////////////////

prevDayClose = request.security(
	syminfo.tickerid,
	"D",
	close[1])

isHtfBullish = close > prevDayClose - PREV_DAY_TOLERANCE

barcolor(isHtfBullish ? color.green : na)

// CASCADE
////////////////////////////////////////////////////////////////////////////////////////////////////

var bool isCascadeActive = false
var int cascadeStartBar = na
var float cascadeHigh = na
var float cascadeLow = na

// falling into cascade
isPreCascadeFalling = ta.lowest(low[1], PRE_CASCADE_BARS) > low

// large displacement
isLargeAbsoluteDrop = high - low > MIN_CASCADE_MOVE

triggerCascade =
     isHtfBullish
     and isPreCascadeFalling
     and isLargeAbsoluteDrop

if triggerCascade
	isCascadeActive := true
	cascadeStartBar := bar_index
	cascadeHigh := high
	cascadeLow := low

// expire cascade after 5 bars
isCascadeExpired =
	 isCascadeActive
	 and bar_index - cascadeStartBar > 5

if isCascadeExpired
	isCascadeActive := false

plotshape(triggerCascade, style = shape.triangledown, location = location.abovebar, size = size.small, color = color.red)


// ENTRY
////////////////////////////////////////////////////////////////////////////////////////////////////

// retrace level fixed to cascade bar
entryLevel =
	 isCascadeActive
	 ? cascadeLow + (cascadeHigh - cascadeLow) * RETRACE_PERCENT
	 : na

triggerEntry =
	 isCascadeActive
	 and bar_index > cascadeStartBar
	 and high > entryLevel

if triggerEntry
	isCascadeActive := false

plot(
	 triggerEntry ? entryLevel : na,
	 style = plot.style_circles,
	 linewidth = 3,
	 color = color.green)