//@version=6
indicator(
    "SIL engine",
    overlay = true,
    max_boxes_count = 500,
    max_bars_back = 2000)

// INPUT
////////////////////////////////////////////////////////////////////////////////////////////////////

// higher timeframe
HTF_TIMEFRAME = "60"
HTF_SMA_LENGTH = 50

// cascade
PRE_CASCADE_BARS = 60
CASCADE_BARS = 1
MIN_CASCADE_MOVE = 0.35

// entry
RETRACE_PERCENT = 0.5

// HTF REGIME
////////////////////////////////////////////////////////////////////////////////////////////////////

htf = request.security(syminfo.tickerid, HTF_TIMEFRAME, close)
smaHtf = request.security(syminfo.tickerid, HTF_TIMEFRAME,
     ta.sma(close, HTF_SMA_LENGTH))
isHtfRising = request.security(syminfo.tickerid, HTF_TIMEFRAME,
     ta.sma(close, HTF_SMA_LENGTH) > ta.sma(close, HTF_SMA_LENGTH)[1])
isHtfBull = htf > smaHtf and isHtfRising

barcolor(isHtfBull ? color.green : na)

// CASCADE
////////////////////////////////////////////////////////////////////////////////////////////////////

var bool isCascadeActive = false
var bool isReversalReady = false
var int cascadeStartBar = na
var float cascadeLow = na
var float cascadeHigh = na
var float cascadeMid = na

isPreCascadeFalling = ta.lowest(low[1], PRE_CASCADE_BARS) > low
recentHigh = ta.highest(high, CASCADE_BARS)
displacementDown = recentHigh - low
isLargeAbsoluteDrop = displacementDown > MIN_CASCADE_MOVE

triggerCascade =
     isHtfBull
     and isPreCascadeFalling
     and isLargeAbsoluteDrop

if triggerCascade
    isCascadeActive := true
    isReversalReady := true
    cascadeStartBar := bar_index
    cascadeLow := low
    cascadeHigh := recentHigh
    cascadeMid := (cascadeHigh + cascadeLow) * 0.5

// expire cascade regime after 10 bars
isCascadeExpired =
	 isCascadeActive
	 and bar_index - cascadeStartBar > 9

if isCascadeExpired
	isCascadeActive := false
	isReversalReady := false

plotshape(triggerCascade, style = shape.triangledown, location = location.abovebar, size = size.small, color = color.red)

// ENTRY
////////////////////////////////////////////////////////////////////////////////////////////////////

var float regimeLow = na
var float regimeHigh = na
var float entryLevel = na

// initialize regime on cascade
if triggerCascade
	regimeHigh := cascadeHigh
	regimeLow := cascadeLow

// update regime low while active
if isCascadeActive and bar_index > cascadeStartBar
	regimeLow := math.min(regimeLow, low)

// compute retrace level
entryLevel := isCascadeActive ? regimeLow + (regimeHigh - regimeLow) * RETRACE_PERCENT : na

// entry trigger (must occur after cascade bar)
triggerEntry =
	 isCascadeActive
      and isHtfBull
	 and bar_index > cascadeStartBar
	 and high > entryLevel

if triggerEntry
	isCascadeActive := false
	isReversalReady := false

plot(
	 triggerEntry ? entryLevel : na,
	 style = plot.style_circles,
	 linewidth = 3,
	 color = color.green)
