//@version=6
indicator(
    "SIL engine",
    overlay = true,
    max_boxes_count = 500,
    max_bars_back = 2000)

// INPUT
////////////////////////////////////////////////////////////////////////////////////////////////////

// higher timeframe
HTF_TIMEFRAME = "60" // minutes
HTF_SMA_LENGTH = 50

// momentum / velocity
CASCADE_VELOCITY_BARS = 18
STRUCTURE_DISPLACEMENT_BARS = 20
STRUCTURE_BASELINE_BARS = 120
SMOOTH_BARS = 6
ACCELERATION_BARS = 4
ACCELERATION_PERCENT = 12.0

// cascade detection
BAR_STRENGTH_RATIO = 0.65
MIN_CASCADE_MOVE = 0.4

// cascade exhaustion / reversal readiness
REVERSAL_INVALIDATION_WINDOW = 5

// mgc context (not gating)
MGC_SYMBOL = "MGC1!"
MGC_MOMENTUM_BARS = 20

// INIT
////////////////////////////////////////////////////////////////////////////////////////////////////

// lifecycle
var bool isCascadeActive = false
var bool isReversalReady = false
var bool isLongActive = false
var int cascadeStartBar = na
var float cascadeLow = na
var float cascadeHigh = na
var int stalledCount = 0
var bool isStalled = false
var int entryBar = na
var float entryPrice = na
var bool isMgcConfirming = false
var bool isSilverLeading = false

// current velocity
currentVelocity = math.abs(close - close[1])
smaCurrentVelocity = ta.sma(currentVelocity, CASCADE_VELOCITY_BARS)

// structure velocity, momentum, acceleration
structureVelocity = math.abs(close - close[STRUCTURE_DISPLACEMENT_BARS]) / STRUCTURE_DISPLACEMENT_BARS
smaStructureVelocity = ta.sma(structureVelocity, STRUCTURE_BASELINE_BARS)
rawMomentumPercent = smaStructureVelocity > 0 ? (structureVelocity / smaStructureVelocity - 1.0) * 100.0 : 0
momentum = ta.sma(rawMomentumPercent, SMOOTH_BARS)
acceleration = momentum - momentum[ACCELERATION_BARS]

// bar range
barRange = high - low
smaBarRange = ta.sma(barRange, CASCADE_VELOCITY_BARS)
downBody = open - close
upBody = close - open
bodyRangeRatioDown = downBody / barRange
bodyRangeRatioUp = upBody / barRange
higherWickPercent = (close - low) / barRange

// HTF REGIME
////////////////////////////////////////////////////////////////////////////////////////////////////

htf = request.security(syminfo.tickerid, HTF_TIMEFRAME, close)
smaHtf = request.security(syminfo.tickerid, HTF_TIMEFRAME,
     ta.sma(close, HTF_SMA_LENGTH))
isHtfSmaRising = request.security(syminfo.tickerid, HTF_TIMEFRAME,
     ta.sma(close, HTF_SMA_LENGTH) > ta.sma(close, HTF_SMA_LENGTH)[1])
isHtfPriceAboveSma = htf > smaHtf
isHtfBull = isHtfPriceAboveSma and isHtfSmaRising

// plot
barcolor(isHtfBull ? color.green : na)

// CASCADE
////////////////////////////////////////////////////////////////////////////////////////////////////

largestRecentRange = ta.highest(barRange[1], 10)
isShockBar = barRange > largestRecentRange
isStrongDownBar = bodyRangeRatioDown > BAR_STRENGTH_RATIO
absoluteDrop = open - low
isLargeAbsoluteDrop = absoluteDrop > MIN_CASCADE_MOVE
triggerCascade = isHtfBull and isShockBar and isStrongDownBar and isLargeAbsoluteDrop

if triggerCascade
    isCascadeActive := true
    isReversalReady := true
    cascadeStartBar := bar_index
    cascadeLow := low

// plot
plotshape(triggerCascade, style = shape.triangledown, location = location.abovebar, size = size.small, color = color.red)

// STALLED / REVERSAL READINESS
////////////////////////////////////////////////////////////////////////////////////////////////////

isWithinInvalidationWindow = isCascadeActive and bar_index > cascadeStartBar and cascadeStartBar + REVERSAL_INVALIDATION_WINDOW >= bar_index
continuationDrop = cascadeLow - low
isMeaningfulContinuation = continuationDrop > MIN_CASCADE_MOVE * 0.5
isCascadeAgain = triggerCascade and bar_index > cascadeStartBar

triggerReversalInvalidated =
     isWithinInvalidationWindow and
     (isMeaningfulContinuation or isCascadeAgain)

isWithinEntryWindow = isCascadeActive and bar_index > cascadeStartBar and cascadeStartBar + REVERSAL_INVALIDATION_WINDOW >= bar_index
triggerEntryValid = isWithinEntryWindow and not triggerReversalInvalidated

if isCascadeActive and bar_index > cascadeStartBar + REVERSAL_INVALIDATION_WINDOW
    isCascadeActive := false

// plot
plotshape(triggerEntryValid, style = shape.circle, location = location.belowbar, size = size.tiny, color = color.blue)







