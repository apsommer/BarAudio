//@version=6
indicator(
    "SIL engine",
    overlay = true,
    max_boxes_count = 500,
    max_bars_back = 2000)

// INPUT
////////////////////////////////////////////////////////////////////////////////////////////////////

PRE_CASCADE_LOOKBACK = 15
MIN_CASCADE_RANGE = 0.4
BEARISH_RANGE_RATIO = 0.4

ENTRY_PERCENT = 0.2
TAKE_PROFIT_PERCENT = 0.8

// lifecycle
var int cascadeBarIndex = na
var float regimeHigh = na
var float regimeLow = na
var bool isSetupActive = false
var bool isTradeActive = false
var float entryPrice = na
var int tradeStartBar = na
var float tradeHigh = na
var float tradeLow = na
var box tradeBox = na

// CASCADE
////////////////////////////////////////////////////////////////////////////////////////////////////

isPreCascadeWeak = ta.lowest(low[1], PRE_CASCADE_LOOKBACK) > low
isLargeCascadeBar = high - low > MIN_CASCADE_RANGE
isBearishClose = high - low > 0 and (high - close) / (high - low) > BEARISH_RANGE_RATIO
isDownBar = high[1] > high

isCascadeTrigger =
     isPreCascadeWeak
     and isLargeCascadeBar
     and isBearishClose
     and isDownBar
     and not isSetupActive

if isCascadeTrigger
    regimeHigh := high
    regimeLow := low
    isSetupActive := true
    cascadeBarIndex := bar_index

plotshape(isCascadeTrigger, style = shape.triangledown, location = location.abovebar, size = size.small, color = color.red)

// SNAPBACK SCALP
////////////////////////////////////////////////////////////////////////////////////////////////////

cascadeRange = regimeHigh - regimeLow

entryLevel = regimeLow + cascadeRange * ENTRY_PERCENT
stopLoss = regimeLow - cascadeRange * ENTRY_PERCENT
takeProfit = regimeLow + cascadeRange * TAKE_PROFIT_PERCENT

isSetupInvalid = isSetupActive and low < stopLoss
plot(isSetupInvalid ? stopLoss : na, style = plot.style_circles, linewidth = 3, color = color.red)

if isSetupInvalid
    isSetupActive := false

// triggerEntry = isSetupActive and high > entryLevel and not isTradeActive
triggerEntry =
     isSetupActive and
     bar_index > cascadeBarIndex and
     high > entryLevel

if triggerEntry

    isTradeActive := true
    isSetupActive := false
    entryPrice := entryLevel

    tradeHigh := high
    tradeLow := low
    tradeStartBar := bar_index
    tradeBox := box.new(bar_index, entryPrice, bar_index, entryPrice, bgcolor = color.new(color.blue, 85), border_color = color.blue)

plot(triggerEntry ? entryLevel : na, style = plot.style_circles, linewidth = 3, color = color.blue)

isStopLoss = isTradeActive and stopLoss > low
isTakeProfit = isTradeActive and high > takeProfit

if isTradeActive and not na(tradeBox)

    tradeHigh := math.max(tradeHigh, high)
    tradeLow := math.min(tradeLow, low)

    box.set_right(tradeBox, bar_index)
    box.set_top(tradeBox, tradeHigh)
    box.set_bottom(tradeBox, tradeLow)

if isStopLoss

    isSameBar = tradeStartBar == bar_index

    isTradeActive := false

    if isSameBar
        line.new(bar_index, entryPrice, bar_index, stopLoss, color = color.red, width = 3)
    else
        box.set_bgcolor(tradeBox, color.new(color.red, 80))
        box.set_border_color(tradeBox, color.red)
        box.set_top(tradeBox, entryPrice)
        box.set_bottom(tradeBox, stopLoss)

else if isTakeProfit

    isSameBar = tradeStartBar == bar_index

    isTradeActive := false

    if isSameBar
        line.new(bar_index, entryPrice, bar_index, takeProfit, color = color.green, width = 3)
    else
        box.set_bgcolor(tradeBox, color.new(color.green, 80))
        box.set_border_color(tradeBox, color.green)
        box.set_top(tradeBox, takeProfit)
        box.set_bottom(tradeBox, entryPrice)