{
  "rules": {

    "streams": {
      ".read": "auth != null",
      ".write": false
    },

    "users": {
      "$uid": {
        ".read": "$uid === auth.uid",
        ".write": false
      }
    },

    "tokens": {
      "$uid": {
        ".read": false,
        ".write": "$uid === auth.uid"
      }
    }
  }
}